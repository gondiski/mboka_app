<%= link_to topic_digest_path(digest), data: { turbo: false }, class: "block bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl hover:border-brand-200 transition group" do %>
  <div class="p-6">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <span class="px-3 py-1 bg-brand-100 text-brand-700 text-xs font-bold rounded-full"><%= digest.topic.name %></span>
        <span class="text-xs text-gray-400">Week of <%= digest.week_of.strftime("%b %d, %Y") %></span>
      </div>
      <%= render "favorites/star", digest: digest, favorited: favorited %>
    </div>
    <div class="text-sm text-gray-600 leading-relaxed line-clamp-4">
      <%= truncate_html(digest.content, length: 200) %>
    </div>
    <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-brand-600 group-hover:text-brand-700">
      Read full digest
      <svg class="w-3.5 h-3.5 transform group-hover:translate-x-0.5 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </div>
  </div>
  <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
    <span class="text-xs text-gray-400">Generated <%= time_ago_in_words(digest.created_at) %> ago</span>
    <span class="text-xs font-semibold text-brand-600"><%= digest.topic.name %></span>
  </div>
<% end %>
