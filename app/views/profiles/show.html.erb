<div class="min-h-screen bg-gray-50" x-data="{ activeTab: '<%= @tab %>' }">
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka</span>
        </div>
        <div class="flex items-center gap-4">
          <% if current_user.has_role?(:admin) %>
            <%= link_to "Admin Dashboard", admin_dashboard_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700 transition nav-link" %>
          <% end %>
          <button onclick="confirmSignOut()" class="text-sm font-medium text-gray-500 hover:text-gray-700 cursor-pointer transition">Sign Out</button>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <!-- Profile Header Card -->
    <div class="mb-10 bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden relative">
      <%= topographic_pattern_svg(@user, pattern_id: "profile-topo") %>

      <!-- Profile Info -->
      <div class="px-8 pb-8 -mt-12 relative z-10">
        <div class="flex items-end gap-5">
          <img src="https://api.dicebear.com/9.x/adventurer-neutral/svg?seed=<%= @user.id %>&backgroundColor=fef3c7,fde68a,dcfce7,b6e3f4,c0aede,d1d4f9,ffd5dc,fed7aa,fecdd3" alt="<%= @user.full_name %>" class="w-24 h-24 rounded-2xl shadow-lg border-4 border-white bg-white" />
          <div class="pb-1">
            <h1 class="text-2xl font-black text-gray-900 mb-1"><%= @user.full_name %></h1>
            <p class="text-gray-600 font-medium"><%= @user.designation %></p>
            <p class="text-sm text-gray-400 mt-0.5"><%= @user.email %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-8 bg-gray-100 p-1 rounded-xl w-fit">
      <a href="<%= profile_path(tab: 'profile') %>" :class="activeTab === 'profile' ? 'bg-white shadow-sm text-gray-900' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-lg text-sm font-semibold transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Personal Information
      </a>
      <a href="<%= profile_path(tab: 'digest') %>" :class="activeTab === 'digest' ? 'bg-white shadow-sm text-gray-900' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-lg text-sm font-semibold transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        My Digest
      </a>
      <a href="<%= profile_path(tab: 'favorites') %>" :class="activeTab === 'favorites' ? 'bg-white shadow-sm text-gray-900' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-lg text-sm font-semibold transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Favorites
      </a>
    </div>

    <% if @tab == "digest" %>
      <!-- Digest Tab -->
      <div class="space-y-6">
        <% if @digests.any? %>
          <div class="flex items-start gap-6"
               data-controller="infinite-scroll"
               data-infinite-scroll-page-value="<%= @pagy_digests.page %>"
               data-infinite-scroll-total-pages-value="<%= @pagy_digests.pages %>"
               data-infinite-scroll-base-url-value="/profile?tab=digest">
            <!-- Animated Page Numbers -->
            <%= render "shared/page_indicator", pagy: @pagy_digests, current_page: @pagy_digests.page %>

            <!-- Digest Cards -->
            <div class="flex-1 space-y-4">
              <div data-infinite-scroll-target="container" class="grid md:grid-cols-2 gap-6">
                <% @digests.each do |digest| %>
                  <div data-digest-card>
                    <%= render "digest_card", digest: digest, favorited: @favorited_hashids.include?(digest.to_param) %>
                  </div>
                <% end %>
              </div>

              <% if @pagy_digests.page < @pagy_digests.pages %>
                <div data-infinite-scroll-trigger class="py-6 text-center">
                  <div class="inline-flex items-center gap-2 text-sm text-gray-400">
                    <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    Loading more...
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-12 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            <h3 class="text-xl font-bold text-gray-900 mb-2">No digests yet</h3>
            <p class="text-gray-500">Your weekly digests will appear here once the admin generates them.</p>
          </div>
        <% end %>
      </div>

    <% elsif @tab == "favorites" %>
      <!-- Favorites Tab -->
      <div class="space-y-6">
        <% if @favorited_digests.any? %>
          <div class="flex items-start gap-6"
               data-controller="infinite-scroll"
               data-infinite-scroll-page-value="<%= @pagy_favorites.page %>"
               data-infinite-scroll-total-pages-value="<%= @pagy_favorites.pages %>"
               data-infinite-scroll-base-url-value="/profile?tab=favorites">
            <!-- Animated Page Numbers -->
            <%= render "shared/page_indicator", pagy: @pagy_favorites, current_page: @pagy_favorites.page %>

            <!-- Favorites Cards -->
            <div class="flex-1 space-y-4">
              <div data-infinite-scroll-target="container" class="grid md:grid-cols-2 gap-6">
                <% @favorited_digests.each do |digest| %>
                  <div data-digest-card>
                    <%= render "digest_card", digest: digest, favorited: true %>
                  </div>
                <% end %>
              </div>

              <% if @pagy_favorites.page < @pagy_favorites.pages %>
                <div data-infinite-scroll-trigger class="py-6 text-center">
                  <div class="inline-flex items-center gap-2 text-sm text-gray-400">
                    <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    Loading more...
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-12 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <h3 class="text-xl font-bold text-gray-900 mb-2">No favorites yet</h3>
            <p class="text-gray-500">Star your favorite digests to save them here for quick access.</p>
            <%= link_to "Browse Digests", profile_path(tab: "digest"), class: "mt-4 inline-block px-6 py-2 bg-brand-600 text-white rounded-xl font-semibold hover:bg-brand-700 transition" %>
          </div>
        <% end %>
      </div>

    <% else %>
      <!-- Profile Tab -->
      <%= form_with model: @user, url: profile_path, id: "profile-form", class: "space-y-8" do |f| %>
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Personal Information</h3>
          <div class="space-y-6">
            <div>
              <%= f.label :username, "Username", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                  <span class="text-gray-400 text-sm">@</span>
                </div>
                <%= f.text_field :username, {
                  value: @user.username,
                  placeholder: "your_username",
                  class: "w-full pl-10 pr-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm #{'bg-gray-100 cursor-not-allowed' unless @user.can_change_username?}",
                  disabled: !@user.can_change_username?,
                  pattern: "[a-zA-Z0-9_]+",
                  minlength: 3,
                  maxlength: 24
                } %>
              </div>
              <div class="mt-2">
                <% if @user.username.present? && !@user.can_change_username? %>
                  <p class="text-xs text-amber-600 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Username can be changed again in <strong><%= @user.username_cooldown_display %></strong>
                  </p>
                <% else %>
                  <p class="text-xs text-gray-400">3-24 characters. Letters, numbers, and underscores only. Can be changed once every 48 hours.</p>
                <% end %>
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <%= f.label :full_name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :full_name, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
              </div>
              <div>
                <%= f.label :designation, "Designation", class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :designation, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-gray-900">Your Topics</h3>
            <span class="text-sm font-bold text-brand-600"><%= @user.topics.count %> selected</span>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <% @topics.each do |topic| %>
              <label class="cursor-pointer relative">
                <input type="checkbox" name="user[topic_ids][]" value="<%= topic.id %>" <%= 'checked' if @user.topic_ids.include?(topic.id) %> class="sr-only topic-checkbox">
                <div class="p-3 rounded-xl border-2 border-gray-200 hover:border-brand-300 transition flex items-center justify-between group">
                  <span class="text-sm font-medium text-gray-700"><%= topic.name %></span>
                  <svg class="w-5 h-5 text-brand-600 opacity-0 transform scale-50 transition-all duration-200 check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <!-- Email Preferences -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
          <div class="flex justify-between items-center mb-6">
            <div>
              <h3 class="text-xl font-bold text-gray-900">Email Preferences</h3>
              <p class="text-sm text-gray-500 mt-1">Manage your weekly digest email settings.</p>
            </div>
            <div class="flex items-center gap-2">
              <% if @user.subscribed? %>
                <span class="w-2 h-2 bg-green-400 rounded-full"></span>
                <span class="text-sm font-medium text-green-600">Active</span>
              <% else %>
                <span class="w-2 h-2 bg-red-400 rounded-full"></span>
                <span class="text-sm font-medium text-red-600">Unsubscribed</span>
              <% end %>
            </div>
          </div>
          <p class="text-sm text-gray-600 mb-4">
            You're currently subscribed to receive weekly digests for your selected topics.
            <% if @user.unsubscribed_at.present? %>
              <br><span class="text-gray-400">Unsubscribed on <%= @user.unsubscribed_at.strftime("%B %d, %Y") %>.</span>
            <% end %>
          </p>
          <a href="<%= email_preferences_path(token: @user.unsubscribe_token) %>" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 transition text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Manage Email Preferences
          </a>
        </div>

        <div class="flex justify-end gap-4">
          <button type="button" onclick="confirmSignOut()" class="px-6 py-3 border-2 border-gray-200 text-gray-600 font-semibold rounded-xl hover:bg-gray-100 transition cursor-pointer">Sign Out</button>
          <button type="button" onclick="confirmSaveProfile()" class="px-8 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition shadow-lg cursor-pointer transform hover:-translate-y-0.5">Save Changes</button>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<script>
  function confirmSignOut() {
    Swal.fire({
      title: 'Sign Out?',
      text: 'You will need to sign in again to access your account.',
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#16a34a',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Yes, sign me out',
      cancelButtonText: 'Cancel',
      background: '#ffffff',
      customClass: { popup: 'swal2-border-radius' }
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = '<%= destroy_user_session_path %>';
      }
    });
  }

  function confirmSaveProfile() {
    Swal.fire({
      title: 'Save Changes?',
      text: 'Your profile information and topic selections will be updated.',
      icon: 'info',
      showCancelButton: true,
      confirmButtonColor: '#16a34a',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Yes, save changes',
      cancelButtonText: 'Cancel',
      background: '#ffffff',
      customClass: { popup: 'swal2-border-radius' }
    }).then((result) => {
      if (result.isConfirmed) {
        document.getElementById('profile-form').requestSubmit();
      }
    });
  }
</script>
