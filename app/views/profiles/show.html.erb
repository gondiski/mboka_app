<div class="min-h-screen bg-gray-50" x-data="{ activeTab: '<%= @tab %>' }">
  <!-- Navigation -->
  <nav class="bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka</span>
        </div>
        <div class="flex items-center gap-4">
          <% if current_user.has_role?(:admin) %>
            <%= link_to "Admin Dashboard", admin_dashboard_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700" %>
          <% end %>
          <button onclick="confirmSignOut()" class="text-sm font-medium text-gray-500 hover:text-gray-700 cursor-pointer">Sign Out</button>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <!-- Profile Header with Avatar -->
    <div class="mb-10 flex items-center gap-6">
      <img src="https://api.dicebear.com/9.x/notionists/svg?seed=<%= @user.id %>&backgroundColor=dcfce7,b6e3f4,c0aede,d1d4f9,ffd5dc" alt="<%= @user.full_name %>" class="w-20 h-20 rounded-2xl shadow-lg border-2 border-white bg-white" />
      <div>
        <h1 class="text-3xl font-black text-gray-900 mb-2"><%= @user.full_name %></h1>
        <p class="text-gray-600"><%= @user.designation %></p>
        <p class="text-sm text-gray-400 mt-1"><%= @user.email %></p>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-8 bg-gray-100 p-1 rounded-xl w-fit">
      <a href="<%= profile_path(tab: 'profile') %>" :class="activeTab === 'profile' ? 'bg-white shadow-sm text-gray-900' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-lg text-sm font-semibold transition">
        Personal Information
      </a>
      <a href="<%= profile_path(tab: 'digest') %>" :class="activeTab === 'digest' ? 'bg-white shadow-sm text-gray-900' : 'text-gray-500 hover:text-gray-700'" class="px-6 py-2.5 rounded-lg text-sm font-semibold transition">
        My Digest
      </a>
    </div>

    <% if @tab == "digest" %>
      <!-- Digest Tab -->
      <div class="space-y-6">
        <% if @digests.any? %>
          <!-- Newspaper Grid -->
          <div class="grid md:grid-cols-2 gap-6">
            <% @digests.each do |digest| %>
              <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition group">
                <div class="p-6">
                  <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2">
                      <span class="px-3 py-1 bg-brand-100 text-brand-700 text-xs font-bold rounded-full"><%= digest.topic.name %></span>
                      <span class="text-xs text-gray-400">Week of <%= digest.week_of.strftime("%b %d, %Y") %></span>
                    </div>
                    <%= render "favorites/star", digest: digest, favorited: @favorited_ids.include?(digest.id) %>
                  </div>
                  <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed">
                    <%= simple_format(digest.content) %>
                  </div>
                </div>
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
                  <span class="text-xs text-gray-400">Generated <%= time_ago_in_words(digest.created_at) %> ago</span>
                  <span class="text-xs font-semibold text-brand-600"><%= digest.topic.name %></span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-12 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            <h3 class="text-xl font-bold text-gray-900 mb-2">No digests yet</h3>
            <p class="text-gray-500">Your weekly digests will appear here once the admin generates them.</p>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Profile Tab -->
      <%= form_with model: @user, url: profile_path, id: "profile-form", class: "space-y-8" do |f| %>
        <!-- Personal Information -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Personal Information</h3>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <%= f.label :full_name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.text_field :full_name, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
            </div>
            <div>
              <%= f.label :designation, "Designation", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.text_field :designation, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
            </div>
          </div>
        </div>

        <!-- Topic Selection -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-gray-900">Your Topics</h3>
            <span class="text-sm font-bold text-brand-600"><%= @user.topics.count %> selected</span>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            <% @topics.each do |topic| %>
              <label class="cursor-pointer relative">
                <input type="checkbox" name="user[topic_ids][]" value="<%= topic.id %>" <%= 'checked' if @user.topic_ids.include?(topic.id) %> class="sr-only topic-checkbox">
                <div class="p-3 rounded-xl border-2 border-gray-200 hover:border-brand-300 transition flex items-center justify-between group">
                  <span class="text-sm font-medium text-gray-700"><%= topic.name %></span>
                  <svg class="w-5 h-5 text-brand-600 opacity-0 transform scale-50 transition-all duration-200 check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex justify-end gap-4">
          <button type="button" onclick="confirmSignOut()" class="px-6 py-3 border-2 border-gray-200 text-gray-600 font-semibold rounded-xl hover:bg-gray-100 transition cursor-pointer">Sign Out</button>
          <button type="button" onclick="confirmSaveProfile()" class="px-8 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition shadow-lg cursor-pointer transform hover:-translate-y-0.5">Save Changes</button>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<script>
  function confirmSignOut() {
    Swal.fire({
      title: 'Sign Out?',
      text: 'You will need to sign in again to access your account.',
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#16a34a',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Yes, sign me out',
      cancelButtonText: 'Cancel',
      background: '#ffffff',
      customClass: { popup: 'swal2-border-radius' }
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = '<%= destroy_user_session_path %>';
      }
    });
  }

  function confirmSaveProfile() {
    Swal.fire({
      title: 'Save Changes?',
      text: 'Your profile information and topic selections will be updated.',
      icon: 'info',
      showCancelButton: true,
      confirmButtonColor: '#16a34a',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Yes, save changes',
      cancelButtonText: 'Cancel',
      background: '#ffffff',
      customClass: { popup: 'swal2-border-radius' }
    }).then((result) => {
      if (result.isConfirmed) {
        document.getElementById('profile-form').requestSubmit();
      }
    });
  }
</script>
