<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="md:flex md:items-center md:justify-between border-b border-slate-800 pb-6 mb-8">
      <div class="flex-1 min-w-0">
        <h2 class="text-2xl font-bold tracking-tight text-slate-100 sm:truncate"><%= @user.full_name %></h2>
        <p class="text-sm text-slate-400 mt-1"><%= @user.designation %></p>
      </div>
      <% if current_user.has_role?(:admin) %>
        <%= link_to "Admin Panel Dashboard", admin_dashboard_path, class: "inline-flex items-center px-4 py-2 bg-emerald-500 text-slate-950 text-xs font-bold uppercase tracking-wider rounded-lg hover:opacity-90 transition" %>
      <% end %>
    </div>
  
    <%= form_with model: @user, url: profile_path, class: "space-y-8" do |f| %>
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-4">
        <h3 class="text-lg font-medium text-slate-200">Personal Context Coordinates</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :full_name, class: "block text-xs font-semibold text-slate-400 mb-1" %>
            <%= f.text_field :full_name, class: "block w-full rounded-lg bg-slate-950 border-slate-800 text-slate-100 text-sm focus:ring-emerald-500" %>
          </div>
          <div>
            <%= f.label :designation, class: "block text-xs font-semibold text-slate-400 mb-1" %>
            <%= f.text_field :designation, class: "block w-full rounded-lg bg-slate-950 border-slate-800 text-slate-100 text-sm focus:ring-emerald-500" %>
          </div>
        </div>
      </div>
  
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h3 class="text-lg font-medium text-slate-200 mb-4">Autonomous Stream Filters</h3>
        <div class="grid grid-cols-2 gap-3">
          <% @topics.each do |topic| %>
            <label class="flex items-center p-3 rounded-lg bg-slate-950 border border-slate-800 hover:border-slate-700 cursor-pointer select-none">
              <%= check_box_tag "user[topic_ids][]", topic.id, @user.topic_ids.include?(topic.id), class: "h-4 w-4 rounded border-slate-800 bg-slate-900 text-emerald-500 focus:ring-0" %>
              <span class="ml-3 text-sm text-slate-300 font-medium"><%= topic.name %></span>
            </label>
          <% end %>
        </div>
      </div>
  
      <div class="flex justify-end gap-3">
        <%= link_to "Terminate Active Session", destroy_user_session_path, data: { turbo_method: :delete }, class: "px-4 py-2 border border-slate-800 text-slate-400 text-sm font-medium rounded-lg hover:bg-slate-900 transition" %>
        <%= f.submit "Commit Updates", class: "px-6 py-2 bg-slate-100 text-slate-950 text-sm font-bold rounded-lg hover:bg-slate-200 cursor-pointer transition" %>
      </div>
    <% end %>
  </div>