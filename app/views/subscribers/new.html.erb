  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-4xl md:text-5xl font-black text-white mb-6">Ready to Transform Your Career?</h2>
    <p class="text-xl text-brand-100 mb-10 max-w-2xl mx-auto">Join thousands of professionals and entrepreneurs who never miss an opportunity. Start free today.</p>
    <button @click="$dispatch('open-subscribe')" class="inline-block px-8 py-4 bg-white text-brand-700 rounded-full font-bold text-lg hover:bg-brand-50 transition shadow-xl cursor-pointer">Subscribe Now</button>
  </div>
</section>

