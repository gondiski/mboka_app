<div class="min-h-screen bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka</span>
        </div>
        <div class="flex items-center gap-4">
          <% if current_user.has_role?(:admin) %>
            <%= link_to "Admin Dashboard", admin_dashboard_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700" %>
          <% end %>
          <%= link_to "Back to Digests", profile_path(tab: "digest"), class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <!-- Back Link -->
    <div class="mb-6">
      <%= link_to profile_path(tab: "digest"), class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-700 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to My Digest
      <% end %>
    </div>

    <!-- Digest Header -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
      <div class="px-8 py-6 border-b border-gray-100">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 bg-brand-100 text-brand-700 text-xs font-bold rounded-full"><%= @digest.topic.name %></span>
            <span class="text-sm text-gray-500">Week of <%= @digest.week_of.strftime("%B %d, %Y") %></span>
          </div>
          <%= render "favorites/star", digest: @digest, favorited: @favorited %>
        </div>
      </div>

      <!-- Digest Content -->
      <div class="p-8">
        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
          <%= raw inject_utm_links(@digest.content, source: "digest", medium: "email", campaign: @digest.topic.name.parameterize, content: @digest.id) %>
        </div>
      </div>

      <!-- Footer -->
      <div class="px-8 py-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs text-gray-400">Generated <%= time_ago_in_words(@digest.created_at) %> ago</span>
        <span class="text-xs font-semibold text-brand-600"><%= @digest.topic.name %></span>
      </div>
    </div>
  </div>
</div>
