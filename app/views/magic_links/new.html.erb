<div class="min-h-screen flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
      <h2 class="text-3xl font-bold tracking-tight">Access Secure Workspace</h2>
      <p class="mt-2 text-sm text-slate-400">Enter your address below to drop an authenticated workspace shortcut.</p>
    </div>
    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-slate-900 border border-slate-800 rounded-2xl py-8 px-6 shadow-xl">
        <%= form_with url: magic_links_path, class: "space-y-4" do |f| %>
          <div>
            <%= f.label :email, "Registered Account Email", class: "block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1" %>
            <%= f.email_field :email, required: true, class: "block w-full rounded-lg bg-slate-950 border-slate-800 text-slate-100 focus:border-emerald-500 focus:ring-emerald-500/20 text-sm" %>
          </div>
          <%= f.submit "Generate Access Key", class: "w-full py-2.5 px-4 bg-slate-100 text-slate-950 text-sm font-semibold rounded-lg hover:bg-slate-200 transition cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>