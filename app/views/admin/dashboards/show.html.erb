<div class="min-h-screen bg-gray-50">
  <%= render "shared/admin_nav" %>

  <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-black text-gray-900 mb-8">Performance Dashboard</h1>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-6 mb-10">
      <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">New Users (This Week)</p>
        <div class="flex items-end justify-between mt-2">
          <p class="text-3xl font-black text-brand-600"><%= @users_stat[:current] %></p>
          <%= render_trend(@users_stat[:trend]) %>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Emails Sent (This Week)</p>
        <div class="flex items-end justify-between mt-2">
          <p class="text-3xl font-black text-brand-600"><%= @sent_stat[:current] %></p>
          <%= render_trend(@sent_stat[:trend]) %>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Emails Opened (This Week)</p>
        <div class="flex items-end justify-between mt-2">
          <p class="text-3xl font-black text-brand-600"><%= @opened_stat[:current] %></p>
          <%= render_trend(@opened_stat[:trend]) %>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Total Clicks (This Week)</p>
        <div class="flex items-end justify-between mt-2">
          <p class="text-3xl font-black text-brand-600"><%= @clicked_stat[:current] %></p>
          <%= render_trend(@clicked_stat[:trend]) %>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Open Rate (This Week)</p>
        <div class="flex items-end justify-between mt-2">
          <p class="text-3xl font-black text-brand-600"><%= @open_rate_stat[:current] %>%</p>
          <%= render_trend(@open_rate_stat[:trend]) %>
        </div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="grid md:grid-cols-2 gap-8 mb-8">
      <!-- Weekly Open Rate Chart -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-bold text-gray-900">Weekly Open Rate</h3>
          <%= link_to "Full Reports", admin_reports_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700 transition" %>
        </div>
        <div id="weeklyChart" class="w-full" style="height: 280px;"></div>
      </div>

      <!-- Monthly Open Rate Chart -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-bold text-gray-900">Monthly Open Rate</h3>
        </div>
        <div id="monthlyChart" class="w-full" style="height: 280px;"></div>
      </div>
    </div>

    <!-- Digest Performance Over Time -->
    <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 mb-8">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-lg font-bold text-gray-900">Digest Performance Over Time</h3>
        <%= link_to "Full Reports", admin_reports_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700 transition" %>
      </div>
      <div id="performanceChart" class="w-full" style="height: 320px;"></div>
    </div>

    <!-- Analytics Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Top 10 Topics by Open Rate -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-bold text-gray-900">Top 10 Topics by Open Rate</h3>
          <%= link_to "Full Reports", admin_reports_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700 transition" %>
        </div>
        <div id="topicChart" class="w-full" style="height: 400px;"></div>
      </div>

      <!-- Top 5 Weekly Digest Performance -->
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-lg font-bold text-gray-900">Top 5 Weekly Digests</h3>
          <%= link_to "Manage Schedule", admin_digest_schedule_path, class: "text-sm font-semibold text-brand-600 hover:text-brand-700 transition" %>
        </div>
        <% if @digest_page.present? %>
          <div class="space-y-3">
            <% @digest_page.each_with_index do |stat, idx| %>
              <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                <div class="flex items-center gap-3">
                  <span class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold
                    <%= idx == 0 ? 'bg-brand-100 text-brand-700' : 'bg-gray-100 text-gray-500' %>">
                    <%= idx + 1 %>
                  </span>
                  <div>
                    <p class="font-semibold text-gray-900"><%= stat[:topic_name] %></p>
                    <p class="text-sm text-gray-500"><%= stat[:users_reached] %> users reached</p>
                  </div>
                </div>
                <div class="text-right">
                  <span class="text-sm font-bold text-brand-600"><%= stat[:open_rate] %>%</span>
                  <p class="text-xs text-gray-400"><%= stat[:generated_at].strftime("%b %d") %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <p class="text-gray-500">No digests generated this week</p>
            <p class="text-sm text-gray-400 mt-1">Configure your schedule to start sending digests.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
function renderCharts() {
  if (typeof d3 === 'undefined') { setTimeout(renderCharts, 50); return; }
  const brandColor = '#16a34a';
  const brandLight = '#22c55e';
  const brandDark = '#15803d';
  const accentColor = '#f59e0b';
  const gray100 = '#f3f4f6';
  const gray200 = '#e5e7eb';
  const gray300 = '#d1d5db';
  const gray500 = '#6b7280';
  const gray700 = '#374151';
  const gray900 = '#111827';

  // ============ WEEKLY LINE CHART ============
  (function() {
    const rawData = <%= raw @weekly_open_data.to_json %>;
    const data = Object.entries(rawData).map(([key, val]) => ({ label: key, ...val }));

    const container = document.getElementById('weeklyChart');
    const width = container.clientWidth;
    const height = 280;
    const margin = { top: 20, right: 20, bottom: 40, left: 50 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;

    const svg = d3.select('#weeklyChart').append('svg')
      .attr('width', width).attr('height', height);

    const g = svg.append('g').attr('transform', `translate(${margin.left},${margin.top})`);

    const x = d3.scalePoint().domain(data.map(d => d.label)).range([0, innerW]).padding(0.5);
    const y = d3.scaleLinear().domain([0, 100]).range([innerH, 0]);

    // Grid lines
    g.selectAll('.grid-line')
      .data([20, 40, 60, 80, 100])
      .join('line')
      .attr('class', 'grid-line')
      .attr('x1', 0).attr('x2', innerW)
      .attr('y1', d => y(d)).attr('y2', d => y(d))
      .attr('stroke', gray200).attr('stroke-dasharray', '3,3');

    // Area
    const area = d3.area()
      .x(d => x(d.label))
      .y0(innerH)
      .y1(d => y(d.rate))
      .curve(d3.curveMonotoneX);

    g.append('path')
      .datum(data)
      .attr('fill', 'rgba(22,163,74,0.08)')
      .attr('d', area);

    // Line
    const line = d3.line()
      .x(d => x(d.label))
      .y(d => y(d.rate))
      .curve(d3.curveMonotoneX);

    g.append('path')
      .datum(data)
      .attr('fill', 'none')
      .attr('stroke', brandColor)
      .attr('stroke-width', 3)
      .attr('stroke-linecap', 'round')
      .attr('d', line);

    // Dots
    g.selectAll('.dot')
      .data(data)
      .join('circle')
      .attr('cx', d => x(d.label))
      .attr('cy', d => y(d.rate))
      .attr('r', 5)
      .attr('fill', '#fff')
      .attr('stroke', brandColor)
      .attr('stroke-width', 2.5);

    // Tooltip
    const tooltip = d3.select('#weeklyChart').append('div')
      .style('position', 'absolute').style('background', gray900).style('color', '#fff')
      .style('padding', '8px 12px').style('border-radius', '8px').style('font-size', '12px')
      .style('pointer-events', 'none').style('opacity', 0).style('z-index', 10);

    g.selectAll('.hitarea')
      .data(data)
      .join('circle')
      .attr('cx', d => x(d.label))
      .attr('cy', d => y(d.rate))
      .attr('r', 16)
      .attr('fill', 'transparent')
      .on('mouseenter', (event, d) => {
        tooltip.html(`<strong>${d.label}</strong><br>Sent: ${d.sent}<br>Opened: ${d.opened}<br>Rate: ${d.rate}%`)
          .style('left', (event.offsetX + 12) + 'px')
          .style('top', (event.offsetY - 10) + 'px')
          .style('opacity', 1);
      })
      .on('mouseleave', () => tooltip.style('opacity', 0));

    // Axes
    g.append('g').attr('transform', `translate(0,${innerH})`)
      .call(d3.axisBottom(x).tickSize(0).tickPadding(10))
      .selectAll('text').attr('fill', gray500).attr('font-size', '11px');
    g.append('g')
      .call(d3.axisLeft(y).ticks(5).tickFormat(d => d + '%').tickSize(0).tickPadding(10))
      .selectAll('text').attr('fill', gray500).attr('font-size', '11px');
    g.selectAll('.domain').remove();
  })();

  // ============ MONTHLY BAR CHART ============
  (function() {
    const rawData = <%= raw @monthly_open_data.to_json %>;
    const data = Object.entries(rawData).map(([key, val]) => ({ label: key, ...val }));

    const container = document.getElementById('monthlyChart');
    const width = container.clientWidth;
    const height = 280;
    const margin = { top: 20, right: 20, bottom: 50, left: 50 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;

    const svg = d3.select('#monthlyChart').append('svg')
      .attr('width', width).attr('height', height);

    const g = svg.append('g').attr('transform', `translate(${margin.left},${margin.top})`);

    const x = d3.scaleBand().domain(data.map(d => d.label)).range([0, innerW]).padding(0.3);
    const y = d3.scaleLinear().domain([0, 100]).range([innerH, 0]);

    // Grid lines
    g.selectAll('.grid-line')
      .data([20, 40, 60, 80, 100])
      .join('line')
      .attr('x1', 0).attr('x2', innerW)
      .attr('y1', d => y(d)).attr('y2', d => y(d))
      .attr('stroke', gray200).attr('stroke-dasharray', '3,3');

    // Bars
    g.selectAll('.bar')
      .data(data)
      .join('rect')
      .attr('x', d => x(d.label))
      .attr('y', d => y(d.rate))
      .attr('width', x.bandwidth())
      .attr('height', d => innerH - y(d.rate))
      .attr('fill', brandColor)
      .attr('rx', 4)
      .attr('ry', 4);

    // Tooltip
    const tooltip = d3.select('#monthlyChart').append('div')
      .style('position', 'absolute').style('background', gray900).style('color', '#fff')
      .style('padding', '8px 12px').style('border-radius', '8px').style('font-size', '12px')
      .style('pointer-events', 'none').style('opacity', 0).style('z-index', 10);

    g.selectAll('.bar-hitarea')
      .data(data)
      .join('rect')
      .attr('x', d => x(d.label))
      .attr('y', 0)
      .attr('width', x.bandwidth())
      .attr('height', innerH)
      .attr('fill', 'transparent')
      .on('mouseenter', (event, d) => {
        tooltip.html(`<strong>${d.label}</strong><br>Sent: ${d.sent}<br>Opened: ${d.opened}<br>Rate: ${d.rate}%`)
          .style('left', (event.offsetX + 12) + 'px')
          .style('top', (event.offsetY - 10) + 'px')
          .style('opacity', 1);
      })
      .on('mouseleave', () => tooltip.style('opacity', 0));

    // Axes
    g.append('g').attr('transform', `translate(0,${innerH})`)
      .call(d3.axisBottom(x).tickSize(0).tickPadding(10))
      .selectAll('text').attr('fill', gray500).attr('font-size', '10px')
      .attr('transform', 'rotate(-35)').attr('text-anchor', 'end');
    g.append('g')
      .call(d3.axisLeft(y).ticks(5).tickFormat(d => d + '%').tickSize(0).tickPadding(10))
      .selectAll('text').attr('fill', gray500).attr('font-size', '11px');
    g.selectAll('.domain').remove();
  })();

  // ============ PERFORMANCE OVER TIME ============
  (function() {
    const data = <%= raw @digest_performance_data.to_json %>;

    const container = document.getElementById('performanceChart');
    const width = container.clientWidth;
    const height = 320;
    const margin = { top: 20, right: 60, bottom: 40, left: 50 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;

    const svg = d3.select('#performanceChart').append('svg')
      .attr('width', width).attr('height', height);

    const g = svg.append('g').attr('transform', `translate(${margin.left},${margin.top})`);

    const x = d3.scalePoint().domain(data.map(d => d.week)).range([0, innerW]).padding(0.5);
    const y = d3.scaleLinear().domain([0, 100]).range([innerH, 0]);

    // Grid
    g.selectAll('.grid-line')
      .data([20, 40, 60, 80, 100])
      .join('line')
      .attr('x1', 0).attr('x2', innerW)
      .attr('y1', d => y(d)).attr('y2', d => y(d))
      .attr('stroke', gray200).attr('stroke-dasharray', '3,3');

    // Area under open rate
    const area = d3.area()
      .x(d => x(d.week))
      .y0(innerH)
      .y1(d => y(d.rate))
      .curve(d3.curveMonotoneX);

    g.append('path')
      .datum(data)
      .attr('fill', 'rgba(22,163,74,0.06)')
      .attr('d', area);

    // Open rate line
    const line = d3.line()
      .x(d => x(d.week))
      .y(d => y(d.rate))
      .curve(d3.curveMonotoneX);

    g.append('path')
      .datum(data)
      .attr('fill', 'none')
      .attr('stroke', brandColor)
      .attr('stroke-width', 3)
      .attr('stroke-linecap', 'round')
      .attr('d', line);

    // Sent bars (thin, subtle)
    const barWidth = Math.max(12, innerW / data.length * 0.3);
    g.selectAll('.sent-bar')
      .data(data)
      .join('rect')
      .attr('x', d => x(d.week) - barWidth / 2)
      .attr('y', d => y(Math.min(d.sent / (d3.max(data, dd => dd.sent) || 1) * 100, 100)))
      .attr('width', barWidth)
      .attr('height', d => innerH - y(Math.min(d.sent / (d3.max(data, dd => dd.sent) || 1) * 100, 100)))
      .attr('fill', 'rgba(245,158,11,0.25)')
      .attr('rx', 3);

    // Dots on rate line
    g.selectAll('.dot')
      .data(data)
      .join('circle')
      .attr('cx', d => x(d.week))
      .attr('cy', d => y(d.rate))
      .attr('r', 5)
      .attr('fill', '#fff')
      .attr('stroke', brandColor)
      .attr('stroke-width', 2.5);

    // Tooltip
    const tooltip = d3.select('#performanceChart').append('div')
      .style('position', 'absolute').style('background', gray900).style('color', '#fff')
      .style('padding', '8px 12px').style('border-radius', '8px').style('font-size', '12px')
      .style('pointer-events', 'none').style('opacity', 0).style('z-index', 10);

    g.selectAll('.hitarea')
      .data(data)
      .join('circle')
      .attr('cx', d => x(d.week))
      .attr('cy', d => y(d.rate))
      .attr('r', 16)
      .attr('fill', 'transparent')
      .on('mouseenter', (event, d) => {
        tooltip.html(`<strong>Week of ${d.week}</strong><br>Digests: ${d.digests_count}<br>Sent: ${d.sent}<br>Opened: ${d.opened}<br>Rate: ${d.rate}%`)
          .style('left', (event.offsetX + 12) + 'px')
          .style('top', (event.offsetY - 10) + 'px')
          .style('opacity', 1);
      })
      .on('mouseleave', () => tooltip.style('opacity', 0));

    // Legend
    const legend = g.append('g').attr('transform', `translate(${innerW - 140}, 0)`);
    legend.append('line').attr('x1', 0).attr('x2', 20).attr('y1', 0).attr('y2', 0).attr('stroke', brandColor).attr('stroke-width', 3);
    legend.append('text').attr('x', 26).attr('y', 4).text('Open Rate').attr('fill', gray500).attr('font-size', '11px');
    legend.append('rect').attr('x', 0).attr('y', 14).attr('width', 20).attr('height', 8).attr('fill', 'rgba(245,158,11,0.25)').attr('rx', 2);
    legend.append('text').attr('x', 26).attr('y', 22).text('Sent Volume').attr('fill', gray500).attr('font-size', '11px');

    // Axes
    g.append('g').attr('transform', `translate(0,${innerH})`)
      .call(d3.axisBottom(x).tickSize(0).tickPadding(10))
      .selectAll('text').attr('fill', gray500).attr('font-size', '11px');
    g.append('g')
      .call(d3.axisLeft(y).ticks(5).tickFormat(d => d + '%').tickSize(0).tickPadding(10))
      .selectAll('text').attr('fill', gray500).attr('font-size', '11px');
    g.selectAll('.domain').remove();
  })();

  // ============ TOPIC HORIZONTAL BAR CHART ============
  (function() {
    const rawData = <%= raw @topic_open_data.to_json %>;
    const entries = Object.entries(rawData).slice(0, 10);
    const data = entries.map(([name, val]) => ({ name, ...val }));

    const container = document.getElementById('topicChart');
    const width = container.clientWidth;
    const barHeight = 32;
    const gap = 8;
    const height = Math.max(300, data.length * (barHeight + gap) + 40);
    const margin = { top: 10, right: 80, bottom: 20, left: 200 };
    const innerW = width - margin.left - margin.right;
    const innerH = height - margin.top - margin.bottom;

    container.style.height = height + 'px';

    const svg = d3.select('#topicChart').append('svg')
      .attr('width', width).attr('height', height);

    const g = svg.append('g').attr('transform', `translate(${margin.left},${margin.top})`);

    const x = d3.scaleLinear().domain([0, 100]).range([0, innerW]);
    const y = d3.scaleBand().domain(data.map(d => d.name)).range([0, innerH]).padding(0.25);

    // Grid
    g.selectAll('.grid-line')
      .data([20, 40, 60, 80, 100])
      .join('line')
      .attr('x1', d => x(d)).attr('x2', d => x(d))
      .attr('y1', 0).attr('y2', innerH)
      .attr('stroke', gray200).attr('stroke-dasharray', '3,3');

    // Bars
    g.selectAll('.bar')
      .data(data)
      .join('rect')
      .attr('x', 0)
      .attr('y', d => y(d.name))
      .attr('width', d => x(d.rate))
      .attr('height', y.bandwidth())
      .attr('fill', brandColor)
      .attr('rx', 4)
      .attr('ry', 4);

    // Labels (right of bar)
    g.selectAll('.label')
      .data(data)
      .join('text')
      .attr('x', d => x(d.rate) + 8)
      .attr('y', d => y(d.name) + y.bandwidth() / 2)
      .attr('dy', '0.35em')
      .attr('fill', gray700)
      .attr('font-size', '12px')
      .attr('font-weight', '600')
      .text(d => d.rate + '%');

    // Y axis labels
    g.selectAll('.y-label')
      .data(data)
      .join('text')
      .attr('x', -10)
      .attr('y', d => y(d.name) + y.bandwidth() / 2)
      .attr('dy', '0.35em')
      .attr('text-anchor', 'end')
      .attr('fill', gray700)
      .attr('font-size', '12px')
      .text(d => d.name.length > 24 ? d.name.slice(0, 22) + '…' : d.name);

    // Tooltip
    const tooltip = d3.select('#topicChart').append('div')
      .style('position', 'absolute').style('background', gray900).style('color', '#fff')
      .style('padding', '8px 12px').style('border-radius', '8px').style('font-size', '12px')
      .style('pointer-events', 'none').style('opacity', 0).style('z-index', 10);

    g.selectAll('.bar-hitarea')
      .data(data)
      .join('rect')
      .attr('x', 0)
      .attr('y', d => y(d.name))
      .attr('width', innerW)
      .attr('height', y.bandwidth())
      .attr('fill', 'transparent')
      .on('mouseenter', (event, d) => {
        tooltip.html(`<strong>${d.name}</strong><br>Sent: ${d.sent}<br>Opened: ${d.opened}<br>Rate: ${d.rate}%`)
          .style('left', (event.offsetX + 12) + 'px')
          .style('top', (event.offsetY - 10) + 'px')
          .style('opacity', 1);
      })
      .on('mouseleave', () => tooltip.style('opacity', 0));

    g.selectAll('.domain').remove();
    g.selectAll('.tick line').remove();
  })();
}
document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', renderCharts) : renderCharts();
</script>
