<div class="min-h-screen bg-slate-950 text-slate-50 flex">
    <!-- Dynamic Dashboard Navigation sidebar structural framework -->
    <aside class="w-64 border-r border-slate-900 p-6 flex flex-col gap-6">
      <div class="text-xl font-bold bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">Mboka Admin</div>
      <nav class="flex flex-col gap-1 flex-1">
        <%= link_to "Performance Panel", admin_dashboard_path, class: "px-4 py-2.5 rounded-lg bg-slate-900 text-sm font-medium border border-slate-800 text-slate-100" %>
        <%= link_to "Identity Catalogs", admin_users_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-900/50 hover:text-slate-200 transition" %>
        <%= link_to "Digest Schedule", admin_digest_schedule_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-900/50 hover:text-slate-200 transition" %>
        <%= link_to "Exit Workspace", profile_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium text-slate-400 hover:bg-slate-900/50 hover:text-slate-200 mt-auto transition" %>
      </nav>
    </aside>
  
    <!-- Interactive Matrix workspace board display panel grids -->
    <main class="flex-1 p-10 space-y-8">
      <div class="grid grid-cols-4 gap-6">
        <div class="p-6 bg-slate-900 border border-slate-900 rounded-xl shadow-lg"><p class="text-xs uppercase font-semibold text-slate-500 tracking-wider">Monitored Profiles</p><p class="text-3xl font-bold mt-1 text-slate-100"><%= @total_users %></p></div>
        <div class="p-6 bg-slate-900 border border-slate-900 rounded-xl shadow-lg"><p class="text-xs uppercase font-semibold text-slate-500 tracking-wider">Dispatched Summaries</p><p class="text-3xl font-bold mt-1 text-emerald-400"><%= @sent_count %></p></div>
        <div class="p-6 bg-slate-900 border border-slate-900 rounded-xl shadow-lg"><p class="text-xs uppercase font-semibold text-slate-500 tracking-wider">Unwrapped Summaries</p><p class="text-3xl font-bold mt-1 text-cyan-400"><%= @opened_count %></p></div>
        <div class="p-6 bg-slate-900 border border-slate-900 rounded-xl shadow-lg"><p class="text-xs uppercase font-semibold text-slate-500 tracking-wider">Total Active Actions</p><p class="text-3xl font-bold mt-1 text-indigo-400"><%= @clicked_count %></p></div>
      </div>
  
      <!-- Data-Driven Analytics Widget for tracking performance metrics -->
      <div class="bg-slate-900 border border-slate-900 rounded-xl p-6 shadow-xl">
        <h3 class="text-lg font-medium text-slate-200 mb-4">Pipeline Distribution Analytics</h3>
        <div class="grid grid-cols-2 gap-6">
          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">High Intent Subject Anchors</h4>
            <div class="space-y-3">
              <% @common_topics.each do |name, count| %>
                <div>
                  <div class="flex justify-between text-sm mb-1"><span class="text-slate-300 font-medium"><%= name %></span><span class="text-slate-400"><%= count %> tracks</span></div>
                  <div class="w-full bg-slate-950 rounded-full h-1.5"><div class="bg-emerald-500 h-1.5 rounded-full" style="width: <%= (count.to_f / @total_users * 100).round %>%"></div></div>
                </div>
              <% end %>
            </div>
          </div>

          <div>
            <h4 class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-3">Weekly Digest Performance</h4>
            <% if @digest_stats.present? %>
              <div class="space-y-3">
                <% @digest_stats.each do |stat| %>
                  <div class="flex items-center justify-between p-2 bg-slate-800 rounded-lg">
                    <div>
                      <p class="text-sm font-medium text-slate-200"><%= stat[:topic_name] %></p>
                      <p class="text-xs text-slate-500"><%= stat[:users_reached] %> users reached</p>
                    </div>
                    <span class="text-xs text-slate-400"><%= stat[:generated_at].strftime("%b %d") %></span>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-sm text-slate-500">No digests generated this week</p>
            <% end %>
            <div class="mt-3">
              <%= link_to "Manage Schedule", admin_digest_schedule_path, class: "text-xs text-emerald-400 hover:text-emerald-300" %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>