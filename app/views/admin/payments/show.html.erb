<div class="min-h-screen bg-gray-50">
  <%= render "shared/admin_nav" %>

  <div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-black text-gray-900 mb-2">Payments</h1>
    <p class="text-gray-600 mb-8">Manage your Mboka license installments.</p>

    <!-- Status Banner -->
    <% if @settings.all_payments_complete? %>
      <!-- All payments done - permanent access -->
      <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-8 flex items-center gap-4">
        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="font-bold text-green-900">License Fully Paid</p>
          <p class="text-sm text-green-700">Your Mboka license is complete. You have permanent access to the application.</p>
        </div>
      </div>
    <% elsif @settings.trial_active? %>
      <!-- Trial active -->
      <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-8 flex items-center gap-4">
        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="font-bold text-blue-900">Free Trial Active</p>
          <p class="text-sm text-blue-700">
            Your free trial runs until <strong>July 31, 2026</strong>.
            Make your first payment before then to avoid interruption.
          </p>
        </div>
      </div>
    <% elsif @settings.payment_active? %>
      <!-- Payment active -->
      <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-8 flex items-center gap-4">
        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <p class="font-bold text-green-900">Access Active</p>
          <p class="text-sm text-green-700">
            Current installment access expires on <%= @settings.current_payment.expires_at.strftime("%B %d, %Y") %>.
            Pay the next installment before then to maintain access.
          </p>
        </div>
      </div>
    <% else %>
      <!-- Trial expired, no payment - need to pay -->
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-8 flex items-center gap-4">
        <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        </div>
        <div>
          <p class="font-bold text-amber-900">Free Trial Expired</p>
          <p class="text-sm text-amber-700">Your 30-day free trial has ended. Make your first payment to restore access to Mboka.</p>
        </div>
      </div>
    <% end %>

    <!-- Summary Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Total Price</p>
        <p class="text-2xl font-black text-gray-900">$<%= number_with_precision(@summary[:total_price], precision: 0) %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Per Installment</p>
        <p class="text-2xl font-black text-brand-600">$<%= number_with_precision(@summary[:installment_amount], precision: 0) %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Paid</p>
        <p class="text-2xl font-black text-green-600"><%= @summary[:paid_installments] %>/<%= @summary[:total_installments] %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Remaining</p>
        <p class="text-2xl font-black text-amber-600"><%= @summary[:remaining_installments] %></p>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 mb-8">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-bold text-gray-900">Payment Progress</span>
        <span class="text-sm text-gray-500"><%= @summary[:paid_installments] %> of <%= @summary[:total_installments] %> installments</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-3">
        <div class="bg-brand-600 h-3 rounded-full transition-all" style="width: <%= (@summary[:paid_installments].to_f / @summary[:total_installments] * 100).round %>%"></div>
      </div>
      <div class="flex justify-between mt-2">
        <% @summary[:total_installments].times do |i| %>
          <div class="flex items-center gap-1">
            <% if i < @summary[:paid_installments] %>
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <% else %>
              <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <% end %>
            <span class="text-xs text-gray-500">$<%= number_with_precision(@summary[:installment_amount], precision: 0) %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Pay Button or Completion -->
    <% if @settings.all_payments_complete? %>
      <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-8 text-center">
        <svg class="w-16 h-16 text-green-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <p class="font-bold text-green-900 text-xl mb-2">License Fully Paid</p>
        <p class="text-green-700">All <%= @summary[:total_installments] %> installments have been paid. You have permanent access to Mboka.</p>
      </div>
    <% elsif @next_installment %>
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 mb-8">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-bold text-gray-900">Pay Installment #<%= @next_installment %></h3>
            <p class="text-sm text-gray-500 mt-1">
              $<%= number_with_precision(@summary[:installment_amount], precision: 0) %> &mdash; Unlocks 30 days of access
            </p>
          </div>
          <% if @settings.paystack_configured? %>
            <%= button_to checkout_admin_payments_path, method: :post, class: "px-8 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition shadow-lg cursor-pointer transform hover:-translate-y-0.5 flex items-center gap-2" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              Pay Now
            <% end %>
          <% else %>
            <%= link_to "Configure Paystack First", admin_settings_path, class: "px-6 py-3 bg-gray-100 text-gray-500 font-semibold rounded-xl hover:bg-gray-200 transition" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Payment History -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h3 class="font-bold text-gray-900">Payment History</h3>
      </div>
      <% if @payments.any? %>
        <div class="divide-y divide-gray-100">
          <% @payments.each do |payment| %>
            <div class="px-6 py-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full flex items-center justify-center
                  <%= payment.success? ? 'bg-green-100' : payment.failed? ? 'bg-red-100' : 'bg-gray-100' %>">
                  <% if payment.success? %>
                    <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <% elsif payment.failed? %>
                    <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% else %>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <% end %>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Installment #<%= payment.installment_number %></p>
                  <p class="text-xs text-gray-500">
                    <%= payment.created_at.strftime("%b %d, %Y %H:%M") %>
                    <% if payment.paystack_reference %>
                      &middot; Ref: <code class="bg-gray-100 px-1 rounded"><%= payment.paystack_reference %></code>
                    <% end %>
                  </p>
                </div>
              </div>
              <div class="text-right">
                <p class="font-bold text-gray-900">$<%= number_with_precision(payment.amount_dollars, precision: 0) %></p>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= payment.success? ? 'bg-green-100 text-green-800' : payment.failed? ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %>">
                  <%= payment.status.capitalize %>
                </span>
                <% if payment.expires_at %>
                  <p class="text-xs text-gray-400 mt-1">
                    Access until <%= payment.expires_at.strftime("%b %d, %Y") %>
                  </p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-12 text-center text-gray-500">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          <p class="font-medium">No payments yet</p>
          <p class="text-sm mt-1">Your first payment will be recorded here after your trial ends.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
