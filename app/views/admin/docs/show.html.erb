<div class="min-h-screen bg-gray-50">
  <%= render "shared/admin_nav" %>

  <div class="max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h1 class="text-3xl font-black text-gray-900 mb-2">Documentation</h1>
      <p class="text-gray-600">Everything you need to know about managing Mboka.</p>
    </div>

    <!-- Table of Contents -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 mb-8">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Contents</h2>
      <div class="grid md:grid-cols-2 gap-2">
        <a href="#getting-started" class="text-brand-600 hover:text-brand-700 text-sm font-medium">1. Getting Started</a>
        <a href="#digests" class="text-brand-600 hover:text-brand-700 text-sm font-medium">2. Managing Digests</a>
        <a href="#schedule" class="text-brand-600 hover:text-brand-700 text-sm font-medium">3. Digest Schedule</a>
        <a href="#users" class="text-brand-600 hover:text-brand-700 text-sm font-medium">4. User Management</a>
        <a href="#api-keys" class="text-brand-600 hover:text-brand-700 text-sm font-medium">5. API Configuration</a>
        <a href="#payments" class="text-brand-600 hover:text-brand-700 text-sm font-medium">6. Payments & Licensing</a>
        <a href="#reports" class="text-brand-600 hover:text-brand-700 text-sm font-medium">7. Reports & Analytics</a>
        <a href="#troubleshooting" class="text-brand-600 hover:text-brand-700 text-sm font-medium">8. Troubleshooting</a>
      </div>
    </div>

    <!-- 1. Getting Started -->
    <section id="getting-started" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">1</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Getting Started</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">First Steps</h3>
        <ol class="list-decimal pl-5 space-y-2">
          <li><strong>Configure API Keys:</strong> Go to <code>Settings</code> and add your SerpAPI key (for job listings) and Anthropic API key (for AI content generation).</li>
          <li><strong>Set Up Schedule:</strong> Go to <code>Schedule</code> to configure when digests are generated and delivered.</li>
          <li><strong>Add Users:</strong> Go to <code>Users</code> to invite admins, moderators, or bulk import subscribers.</li>
          <li><strong>Review Digests:</strong> Once generated, review and approve digests before they are sent.</li>
        </ol>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">User Roles</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-2">
            <li><strong class="text-purple-700">Admin:</strong> Full access to all features including settings, payments, and user management.</li>
            <li><strong class="text-blue-700">Moderator:</strong> Can review, approve, and reject digests. View-only access to dashboard and reports.</li>
            <li><strong class="text-brand-700">Subscriber:</strong> Receives weekly digest emails. Can manage topics and favorites via their profile.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 2. Managing Digests -->
    <section id="digests" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">2</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Managing Digests</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">How Digests Work</h3>
        <p>Digests are weekly newsletters containing curated content for each topic. The system:</p>
        <ol class="list-decimal pl-5 space-y-2">
          <li><strong>Generates content</strong> using Claude AI based on each topic</li>
          <li><strong>Adds job listings</strong> from SerpAPI for East Africa</li>
          <li>Creates drafts for admin review</li>
          <li>After approval, delivers to subscribed users</li>
        </ol>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Moderation Workflow</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 bg-amber-100 text-amber-700 text-xs font-bold rounded-full">Draft</span>
            <span class="text-gray-400">&rarr;</span>
            <span class="px-2 py-0.5 bg-green-100 text-green-700 text-xs font-bold rounded-full">Approved</span>
            <span class="text-gray-400">&rarr;</span>
            <span class="px-2 py-0.5 bg-blue-100 text-blue-700 text-xs font-bold rounded-full">Sent</span>
          </div>
          <p class="text-sm">Rejected digests can be reset to draft for re-review.</p>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Actions</h3>
        <ul class="list-disc pl-5 space-y-2">
          <li><strong>Approve:</strong> Marks digest as ready for delivery</li>
          <li><strong>Reject:</strong> Marks digest with a reason (not sent to users)</li>
          <li><strong>Bulk Approve:</strong> Approve multiple pending digests at once</li>
          <li><strong>Edit:</strong> Modify digest content before approving</li>
        </ul>
      </div>
    </section>

    <!-- 3. Schedule -->
    <section id="schedule" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">3</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Digest Schedule</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Configuration Options</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-3">
            <li>
              <strong>Delivery Days:</strong> Select which days of the week to send digests (e.g., Monday, Wednesday, Friday).
            </li>
            <li>
              <strong>Delivery Time:</strong> Set the time digests are sent (EAT timezone).
            </li>
            <li>
              <strong>Generation Day:</strong> Choose when content is generated before delivery:
              <ul class="list-disc pl-5 mt-1">
                <li><strong>Same day:</strong> Generate and send on the same day</li>
                <li><strong>1-3 days before:</strong> Generate earlier for review time</li>
                <li><strong>Specific day:</strong> Always generate on a fixed day (e.g., Thursday)</li>
              </ul>
            </li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">How It Works</h3>
        <ol class="list-decimal pl-5 space-y-2">
          <li>When you save the schedule, two Sidekiq cron jobs are created:</li>
          <li><strong>Generation job:</strong> Runs on the generation day to create draft digests</li>
          <li><strong>Delivery job:</strong> Runs on delivery days to send approved digests</li>
          <li>The generation job runs 2 hours before the delivery time</li>
        </ol>

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mt-4">
          <p class="text-sm text-amber-800">
            <strong>Important:</strong> Always review and approve generated digests before the delivery day. Only approved digests are sent to subscribers.
          </p>
        </div>
      </div>
    </section>

    <!-- 4. Users -->
    <section id="users" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">4</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">User Management</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Adding Users</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-2">
            <li><strong>Invite Single User:</strong> Click "Invite User" to send a magic link email</li>
            <li><strong>Bulk Import:</strong> Upload a CSV with columns: <code>fullname</code>, <code>email</code>, <code>designation</code></li>
            <li><strong>Self-Registration:</strong> Users can subscribe via the public landing page</li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">CSV Import Format</h3>
        <div class="bg-gray-900 rounded-xl p-4 mb-4">
          <pre class="text-green-400 text-sm"><code>fullname,email,designation
John Doe,john@example.com,Software Engineer
Jane Smith,jane@example.com,Product Designer</code></pre>
        </div>
        <p>Imported users are automatically activated and assigned topics based on their designation.</p>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Managing Users</h3>
        <ul class="list-disc pl-5 space-y-2">
          <li><strong>Status:</strong> Activate, suspend, or block users</li>
          <li><strong>Roles:</strong> Change user roles (admin, moderator, subscriber)</li>
          <li><strong>Topics:</strong> Users can manage their own topic subscriptions from their profile</li>
        </ul>
      </div>
    </section>

    <!-- 5. API Keys -->
    <section id="api-keys" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">5</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">API Configuration</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">SerpAPI (Google Jobs)</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-2">
            <li><strong>Purpose:</strong> Fetches recent job listings in East Africa</li>
            <li><strong>Get Key:</strong> <a href="https://serpapi.com" target="_blank" class="text-brand-600 underline">serpapi.com</a></li>
            <li><strong>Usage:</strong> Jobs are appended to each digest topic</li>
            <li><strong>Fallback:</strong> If no key, only AI-generated content is used</li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Anthropic Claude</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-2">
            <li><strong>Purpose:</strong> AI-powered content generation for digests</li>
            <li><strong>Get Key:</strong> <a href="https://console.anthropic.com" target="_blank" class="text-brand-600 underline">console.anthropic.com</a></li>
            <li><strong>Model:</strong> Claude Sonnet 4</li>
            <li><strong>Usage:</strong> Scrapes and analyzes VC, grants, accelerators, and funding opportunities</li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Key Storage</h3>
        <p>API keys are stored in the database and cached in Redis for performance. When you update a key, the cache is automatically cleared.</p>
      </div>
    </section>

    <!-- 6. Payments -->
    <section id="payments" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">6</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Payments & Licensing</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Trial Period</h3>
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
          <p>New installations get a <strong>30-day free trial</strong> starting from the first subscriber signup.</p>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">License Payment</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-2">
            <li><strong>Total Price:</strong> $2,000 USD</li>
            <li><strong>Installments:</strong> 3 or 4 payments (configurable)</li>
            <li><strong>Per Installment:</strong> ~$500-$667</li>
            <li><strong>Access:</strong> Each installment unlocks 30 days of access</li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Payment Flow</h3>
        <ol class="list-decimal pl-5 space-y-2">
          <li>Trial expires &rarr; App shows "Free Trial Expired"</li>
          <li>Admin goes to Payments page</li>
          <li>Clicks "Pay Now" to pay</li>
          <li>After payment, app unlocks for 30 days</li>
          <li>After all installments &rarr; Permanent access</li>
        </ol>

      </div>
    </section>

    <!-- 7. Reports -->
    <section id="reports" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">7</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Reports & Analytics</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Available Reports</h3>
        <div class="bg-gray-50 rounded-xl p-4 mb-4">
          <ul class="space-y-2">
            <li><strong>Topic Performance:</strong> Open rates by topic</li>
            <li><strong>Weekly Trends:</strong> Engagement over time</li>
            <li><strong>User Growth:</strong> Subscriber count trends</li>
            <li><strong>Top Topics:</strong> Most popular subscriptions</li>
            <li><strong>Digest Stats:</strong> Send/open/click metrics</li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Date Filtering</h3>
        <p>Use the date range filters to analyze specific periods. Default is 12 weeks.</p>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Sidekiq Dashboard</h3>
        <p>Monitor background jobs at <code>/admin/sidekiq</code>. Shows job queues, retries, and failed jobs.</p>
      </div>
    </section>

    <!-- 8. Troubleshooting -->
    <section id="troubleshooting" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center">
          <span class="text-brand-700 font-bold">8</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Troubleshooting</h2>
      </div>

      <div class="prose prose-sm max-w-none text-gray-600">
        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Common Issues</h3>

        <div class="space-y-4">
          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-gray-900 mb-1">Digests not generating?</p>
            <ul class="list-disc pl-5 text-sm">
              <li>Check that the schedule is active</li>
              <li>Verify Anthropic API key is configured</li>
              <li>Check Sidekiq dashboard for failed jobs</li>
              <li>Ensure topics have subscribers</li>
            </ul>
          </div>

          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-gray-900 mb-1">Emails not sending?</p>
            <ul class="list-disc pl-5 text-sm">
              <li>Verify ZeptoMail/SMTP credentials in <code>.env</code></li>
              <li>Check that digests are approved (only approved digests are sent)</li>
              <li>Check that users are active and subscribed</li>
              <li>Check Sidekiq mailer queue</li>
            </ul>
          </div>

          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-gray-900 mb-1">App locked?</p>
            <ul class="list-disc pl-5 text-sm">
              <li>Trial period may have expired</li>
              <li>Check Payments page for status</li>
              <li>Make a payment to restore access</li>
            </ul>
          </div>

          <div class="bg-gray-50 rounded-xl p-4">
            <p class="font-semibold text-gray-900 mb-1">Job listings not appearing?</p>
            <ul class="list-disc pl-5 text-sm">
              <li>Verify SerpAPI key is configured</li>
              <li>Check SerpAPI quota/credits</li>
              <li>Jobs are only fetched if key is present</li>
            </ul>
          </div>
        </div>

        <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">Clearing Stale Jobs</h3>
        <p>If Sidekiq has stuck jobs, run:</p>
        <div class="bg-gray-900 rounded-xl p-4 mb-4">
          <pre class="text-green-400 text-sm"><code>bin/rails sidekiq:clear_all</code></pre>
        </div>
      </div>
    </section>

    <!-- Back to top -->
    <div class="text-center py-8">
      <a href="#" class="text-brand-600 hover:text-brand-700 font-medium text-sm">Back to Top</a>
    </div>
  </div>
</div>
