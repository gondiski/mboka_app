<div class="min-h-screen bg-gray-50">
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka Admin</span>
        </div>
        <div class="flex items-center gap-6">
          <%= link_to "Dashboard", admin_dashboard_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Users", admin_users_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Digests", admin_digests_path, class: "text-sm font-semibold text-brand-600 nav-link" %>
          <%= link_to "Schedule", admin_digest_schedule_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Settings", admin_settings_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Payments", admin_payments_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Reports", admin_reports_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Sidekiq", "/admin/sidekiq", target: "_blank", class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Profile", profile_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <!-- Back Link -->
    <div class="mb-6">
      <%= link_to admin_digests_path, class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-700 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Digests
      <% end %>
    </div>

    <!-- Header Card -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mb-6">
      <div class="px-8 py-6 border-b border-gray-100">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-2xl font-black text-gray-900"><%= @topic_digest.topic.name %></h1>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold
                <%= case @topic_digest.status
                    when 'draft' then 'bg-amber-100 text-amber-700'
                    when 'approved' then 'bg-green-100 text-green-700'
                    when 'rejected' then 'bg-red-100 text-red-700'
                    when 'sent' then 'bg-blue-100 text-blue-700'
                    end %>">
                <%= @topic_digest.status_label %>
              </span>
            </div>
            <p class="text-sm text-gray-500">Week of <%= @topic_digest.week_of.strftime("%B %d, %Y") %> &middot; Created <%= @topic_digest.created_at.strftime("%b %d, %H:%M") %></p>
          </div>
          <div class="flex items-center gap-3">
            <% if @topic_digest.moderated_by %>
              <div class="text-right">
                <p class="text-sm font-medium text-gray-900"><%= @topic_digest.moderated_by.full_name %></p>
                <p class="text-xs text-gray-500"><%= @topic_digest.moderated_at&.strftime("%b %d, %H:%M") %></p>
              </div>
            <% end %>
            <% if @topic_digest.rejected? && @topic_digest.rejection_reason.present? %>
              <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-2">
                <p class="text-sm font-medium text-red-700">Rejection Reason</p>
                <p class="text-sm text-red-600"><%= @topic_digest.rejection_reason %></p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="p-8">
        <div class="prose prose-gray max-w-none">
          <%= raw @topic_digest.content %>
        </div>
      </div>

      <!-- Actions -->
      <% if @topic_digest.draft? || @topic_digest.rejected? %>
        <div class="px-8 py-5 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <% if @topic_digest.draft? || @topic_digest.rejected? %>
              <%= link_to "Edit Content", edit_admin_digest_path(@topic_digest), class: "px-5 py-2.5 bg-white border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all duration-200 text-sm btn-press" %>
              <%= button_to "Reset to Draft", reset_to_draft_admin_digest_path(@topic_digest), method: :patch, class: "px-5 py-2.5 bg-white border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all duration-200 text-sm cursor-pointer btn-press" if @topic_digest.rejected? %>
            <% end %>
          </div>
          <div class="flex items-center gap-3">
            <% if @topic_digest.draft? || @topic_digest.rejected? %>
              <button type="button" onclick="document.getElementById('reject-modal').classList.remove('hidden')" class="px-5 py-2.5 bg-red-600 text-white font-semibold rounded-xl hover:bg-red-700 transition-all duration-200 text-sm cursor-pointer btn-press glow-red">
                Reject
              </button>
              <%= button_to "Approve", approve_admin_digest_path(@topic_digest), method: :patch, class: "px-5 py-2.5 bg-green-600 text-white font-semibold rounded-xl hover:bg-green-700 transition-all duration-200 text-sm cursor-pointer btn-press glow-green" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Subscriber Preview -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
      <h3 class="text-lg font-bold text-gray-900 mb-4">Subscriber Preview</h3>
      <p class="text-sm text-gray-600 mb-4">This digest will be sent to subscribers of <strong><%= @topic_digest.topic.name %></strong>.</p>
      <% subscriber_count = @topic_digest.topic.users.where(status: "active").count %>
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 bg-brand-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-black text-brand-600"><%= subscriber_count %></p>
            <p class="text-xs text-gray-500">subscribers</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Reject Modal -->
<div id="reject-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm backdrop-fade" onclick="document.getElementById('reject-modal').classList.add('hidden')"></div>
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md relative z-10 p-8 modal-enter">
    <h3 class="text-xl font-bold text-gray-900 mb-4">Reject Digest</h3>
    <%= form_with url: reject_admin_digest_path(@topic_digest), method: :patch, local: true do |f| %>
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">Reason for rejection</label>
        <%= f.text_area :rejection_reason, rows: 3, placeholder: "Explain why this digest is being rejected...", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
      </div>
      <div class="flex justify-end gap-3">
        <button type="button" onclick="document.getElementById('reject-modal').classList.add('hidden')" class="px-5 py-2.5 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 transition text-sm btn-press">
          Cancel
        </button>
        <%= f.submit "Reject Digest", class: "px-5 py-2.5 bg-red-600 text-white font-semibold rounded-xl hover:bg-red-700 transition text-sm cursor-pointer btn-press" %>
      </div>
    <% end %>
  </div>
</div>
