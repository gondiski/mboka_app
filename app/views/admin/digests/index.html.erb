<div class="min-h-screen bg-gray-50">
  <%= render "shared/admin_nav" %>

  <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-black text-gray-900">Digest Moderation</h1>
        <p class="text-gray-600 mt-1">Review and approve digests before they're sent to subscribers.</p>
      </div>
      <div class="flex items-center gap-3">
        <%= button_to run_now_admin_digests_path, method: :post, class: "px-6 py-3 bg-amber-600 text-white font-bold rounded-xl hover:bg-amber-700 transition-all duration-200 shadow-lg cursor-pointer transform hover:-translate-y-0.5 flex items-center gap-2 btn-press" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Run Now
        <% end %>
        <% if @stats[:draft] > 0 %>
          <%= form_with url: bulk_approve_admin_digests_path, method: :patch, local: true, class: "inline" do |f| %>
            <%= f.hidden_field :digest_ids, value: "" %>
            <button type="submit" class="px-6 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition-all duration-200 shadow-lg cursor-pointer transform hover:-translate-y-0.5 flex items-center gap-2 btn-press">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Approve All Pending
            </button>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100 stat-card">
        <p class="text-sm font-medium text-gray-500 mb-1">Total</p>
        <p class="text-2xl font-black text-gray-900"><%= @stats[:total] %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100 stat-card">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></span>
          <p class="text-sm font-medium text-gray-500">Pending</p>
        </div>
        <p class="text-2xl font-black text-amber-600"><%= @stats[:draft] %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100 stat-card">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 bg-green-400 rounded-full"></span>
          <p class="text-sm font-medium text-gray-500">Approved</p>
        </div>
        <p class="text-2xl font-black text-green-600"><%= @stats[:approved] %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100 stat-card">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 bg-red-400 rounded-full"></span>
          <p class="text-sm font-medium text-gray-500">Rejected</p>
        </div>
        <p class="text-2xl font-black text-red-600"><%= @stats[:rejected] %></p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-lg border border-gray-100 stat-card">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 bg-blue-400 rounded-full"></span>
          <p class="text-sm font-medium text-gray-500">Sent</p>
        </div>
        <p class="text-2xl font-black text-blue-600"><%= @stats[:sent] %></p>
      </div>
    </div>

    <!-- Filters -->
    <div x-data="{ scrolled: false }" x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 120 })" class="sticky top-20 z-40 bg-white rounded-2xl shadow-lg border border-gray-100 mb-8 transition-all duration-500 ease-in-out" :class="scrolled ? 'p-3 ml-16' : 'p-6'">
      <%= form_with url: admin_digests_path, method: :get, class: "flex flex-wrap gap-3 items-end" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Status</label>
          <%= f.select :status, options_for_select([["All", ""], ["Pending", "draft"], ["Approved", "approved"], ["Rejected", "rejected"], ["Sent", "sent"]], params[:status]), {}, class: "px-3 py-2 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none text-sm" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Topic</label>
          <%= f.collection_select :topic_id, Topic.all.order(:name), :id, :name, { include_blank: "All Topics", selected: params[:topic_id] }, class: "px-3 py-2 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none text-sm" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Week Of</label>
          <div class="relative" data-controller="flatpickr" data-flatpickr-date-format-value="Y-m-d" data-flatpickr-alt-input-value="true" data-flatpickr-alt-format-value="F j, Y">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <%= f.text_field :week, value: params[:week], data: { flatpickr_target: "input" }, class: "pl-10 px-3 py-2 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none text-sm" %>
          </div>
        </div>
        <div class="flex-1">
          <label class="block text-sm font-medium text-gray-700 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Search</label>
          <%= f.text_field :search, value: params[:search], placeholder: "Search...", class: "w-full px-3 py-2 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none text-sm" %>
        </div>
        <div class="flex gap-2 transition-all duration-500 ease-in-out overflow-hidden" :class="scrolled ? 'h-0 opacity-0' : 'opacity-100'">
          <%= f.submit "Filter", class: "px-5 py-2 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition cursor-pointer text-sm" %>
          <%= link_to "Clear", admin_digests_path, class: "px-5 py-2 bg-gray-100 text-gray-600 font-semibold rounded-xl hover:bg-gray-200 transition text-sm" %>
        </div>
      <% end %>
    </div>

    <!-- Digests Table with Endless Scroll -->
    <div class="flex items-start gap-6"
         data-controller="infinite-scroll"
         data-infinite-scroll-page-value="<%= @pagy.page %>"
         data-infinite-scroll-total-pages-value="<%= @pagy.pages %>"
         data-infinite-scroll-base-url-value="<%= admin_digests_path(request.query_parameters.except(:page)) %>">
      <!-- Animated Page Numbers -->
      <%= render "shared/page_indicator", pagy: @pagy, current_page: @pagy.page %>

      <div class="flex-1 bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <% if @topic_digests.any? %>
          <table class="min-w-full divide-y divide-gray-100">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500">Topic</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500">Week Of</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500">Status</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500">Moderated By</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500">Content Preview</th>
                <th class="text-right px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50" data-infinite-scroll-target="container">
              <% @topic_digests.each do |digest| %>
                <tr class="table-row-hover" data-digest-card>
                  <td class="px-6 py-4">
                    <span class="font-semibold text-gray-900"><%= digest.topic.name %></span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">
                    <%= digest.week_of.strftime("%b %d, %Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case digest.status %>
                    <% when 'draft' %>
                      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-200 badge-pulse">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Pending
                      </span>
                    <% when 'approved' %>
                      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-green-50 text-green-700 border border-green-200 badge-pulse">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Approved
                      </span>
                    <% when 'rejected' %>
                      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-red-50 text-red-700 border border-red-200 badge-pulse">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Rejected
                      </span>
                    <% when 'sent' %>
                      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-blue-50 text-blue-700 border border-blue-200 badge-pulse">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        Sent
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600">
                    <% if digest.moderated_by %>
                      <div class="flex items-center gap-2">
                        <img src="https://api.dicebear.com/9.x/adventurer-neutral/svg?seed=<%= digest.moderated_by.id %>&backgroundColor=fef3c7,fde68a,dcfce7,b6e3f4,c0aede,d1d4f9,ffd5dc,fed7aa,fecdd3" class="w-6 h-6 rounded-full bg-white" alt="">
                        <div>
                          <p class="font-medium text-gray-900"><%= digest.moderated_by.full_name %></p>
                          <p class="text-xs text-gray-400"><%= digest.moderated_at&.strftime("%b %d, %H:%M") %></p>
                        </div>
                      </div>
                    <% else %>
                      <span class="text-gray-400">—</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4">
                    <p class="text-sm text-gray-600 line-clamp-2 max-w-md"><%= strip_tags(digest.content).truncate(120) %></p>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center justify-end gap-2">
                      <%= link_to admin_digest_path(digest), class: "px-3 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 bg-gray-100 hover:bg-gray-200 rounded-lg transition-all duration-200 inline-flex items-center gap-1 btn-press" do %>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        View
                      <% end %>
                      <% if digest.draft? || digest.rejected? %>
                        <%= button_to approve_admin_digest_path(digest), method: :patch, class: "px-3 py-1.5 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-all duration-200 cursor-pointer inline-flex items-center gap-1 btn-press glow-green" do %>
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                          Approve
                        <% end %>
                      <% end %>
                      <% if digest.draft? %>
                        <%= button_to reject_admin_digest_path(digest), method: :patch, data: { turbo: false }, class: "px-3 py-1.5 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-all duration-200 cursor-pointer inline-flex items-center gap-1 btn-press glow-red" do %>
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                          Reject
                        <% end %>
                      <% end %>
                      <% if policy(digest).destroy? %>
                        <%= button_to admin_digest_path(digest), method: :delete, data: { confirm: "Are you sure you want to delete this digest?" }, class: "px-3 py-1.5 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-all duration-200 cursor-pointer inline-flex items-center gap-1 btn-press" do %>
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                          Delete
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>

          <!-- Endless Scroll Trigger -->
          <% if @pagy.page < @pagy.pages %>
            <div data-infinite-scroll-trigger class="py-4 text-center">
              <div class="inline-flex items-center gap-2 text-sm text-gray-400">
                <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                Loading more digests...
              </div>
            </div>
          <% end %>

          <!-- Footer -->
          <div class="bg-gray-50 px-6 py-4 border-t border-gray-100">
            <span class="text-sm text-gray-500">
              Showing page <span class="font-semibold text-gray-700" data-current-page><% @pagy.page.to_s.chars.each do |c| %><span class="digit inline-block"><%= c %></span><% end %></span> of <%= @pagy.pages %> (<%= @pagy.count %> digests)
            </span>
          </div>
        <% else %>
          <div class="text-center py-16">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <p class="text-gray-500 text-lg font-medium">No digests found</p>
            <p class="text-gray-400 text-sm mt-1">Digests will appear here once generated.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
