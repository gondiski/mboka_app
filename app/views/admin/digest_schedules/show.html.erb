<div class="min-h-screen bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka Admin</span>
        </div>
        <div class="flex items-center gap-6">
          <%= link_to "Dashboard", admin_dashboard_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
          <%= link_to "Users", admin_users_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
          <%= link_to "Schedule", admin_digest_schedule_path, class: "text-sm font-semibold text-brand-600" %>
          <%= link_to "Profile", profile_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-black text-gray-900 mb-2">Digest Schedule</h1>
    <p class="text-gray-600 mb-8">Configure when intelligence digests are generated and delivered to subscribers.</p>

    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-8">
      <%= form_with model: @schedule, url: admin_digest_schedule_path, method: :patch, class: "space-y-8" do |f| %>
        <!-- Delivery Days -->
        <div>
          <label class="block text-sm font-bold text-gray-900 mb-4">Delivery Days</label>
          <div class="grid grid-cols-7 gap-3">
            <% DigestSchedule::DAYS_OF_WEEK.each do |day_name, day_num| %>
              <label class="flex flex-col items-center gap-2 cursor-pointer group">
                <%= f.check_box :days, { multiple: true, checked: @schedule.days&.include?(day_num), class: "sr-peer" }, day_num, nil %>
                <div class="w-12 h-12 rounded-xl border-2 border-gray-200 flex items-center justify-center text-sm font-bold text-gray-500 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:text-brand-700 transition group-hover:border-gray-300">
                  <%= day_name[0..2] %>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <!-- Delivery Time -->
        <div>
          <label class="block text-sm font-bold text-gray-900 mb-2">Delivery Time</label>
          <%= f.time_field :send_time, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
        </div>

        <!-- Active Toggle -->
        <div class="flex items-center justify-between p-5 bg-gray-50 rounded-xl border border-gray-200">
          <div>
            <p class="font-bold text-gray-900">Enable Schedule</p>
            <p class="text-sm text-gray-500">Toggle to activate or pause digest delivery</p>
          </div>
          <label class="relative inline-flex cursor-pointer">
            <%= f.check_box :active, { class: "sr-peer" }, "true", "false" %>
            <div class="w-12 h-6 bg-gray-300 rounded-full peer peer-checked:bg-brand-500 transition after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-6 shadow-inner"></div>
          </label>
        </div>

        <!-- Submit -->
        <div class="flex items-center gap-4">
          <%= f.submit "Update Schedule", class: "px-8 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 cursor-pointer transition shadow-lg transform hover:-translate-y-0.5" %>
          <span class="text-sm text-gray-500">
            <% if @schedule.cron_expression.present? %>
              Cron: <code class="text-gray-700 bg-gray-100 px-2 py-1 rounded"><%= @schedule.cron_expression %></code>
            <% else %>
              No active schedule
            <% end %>
          </span>
        </div>
      <% end %>
    </div>

    <!-- How It Works -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
      <h3 class="text-lg font-bold text-gray-900 mb-4">How It Works</h3>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
          <div class="w-8 h-8 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-brand-700 font-bold text-sm">1</span>
          </div>
          <p class="text-sm text-gray-600">Each scheduled run queries the LLM once per unique topic across all subscribers.</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
          <div class="w-8 h-8 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-brand-700 font-bold text-sm">2</span>
          </div>
          <p class="text-sm text-gray-600">Results are cached per topic for the current week to avoid redundant API calls.</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
          <div class="w-8 h-8 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-brand-700 font-bold text-sm">3</span>
          </div>
          <p class="text-sm text-gray-600">Each subscriber receives a compiled email combining their chosen topics.</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
          <div class="w-8 h-8 bg-brand-100 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="text-brand-700 font-bold text-sm">4</span>
          </div>
          <p class="text-sm text-gray-600">All link opens and clicks are tracked via Ahoy and visible on the Dashboard.</p>
        </div>
      </div>
    </div>
  </div>
</div>
