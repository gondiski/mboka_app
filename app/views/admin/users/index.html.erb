<div class="min-h-screen bg-gray-50" x-data="{ showInviteModal: false }">
  <!-- Navigation -->
  <nav class="bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka Admin</span>
        </div>
        <div class="flex items-center gap-6">
          <%= link_to "Dashboard", admin_dashboard_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
          <%= link_to "Users", admin_users_path, class: "text-sm font-semibold text-brand-600" %>
          <%= link_to "Schedule", admin_digest_schedule_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
          <%= link_to "Profile", profile_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-black text-gray-900">User Management</h1>
      <div class="flex items-center gap-3">
        <%= form_with url: import_admin_users_path, method: :post, multipart: true, class: "flex items-center gap-3" do |f| %>
          <%= f.file_field :file, accept: '.csv', required: true, class: "text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 text-gray-500 cursor-pointer" %>
          <%= f.submit "Bulk Import", class: "px-4 py-2 bg-brand-600 text-white text-sm font-bold rounded-xl hover:bg-brand-700 cursor-pointer transition shadow-md" %>
        <% end %>
        <button @click="showInviteModal = true" class="px-4 py-2 bg-brand-600 text-white text-sm font-bold rounded-xl hover:bg-brand-700 cursor-pointer transition shadow-md flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Invite User
        </button>
      </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">User</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Designation</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Role</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Topics</th>
            <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Status</th>
            <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-gray-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <img src="https://api.dicebear.com/9.x/notionists/svg?seed=<%= user.id %>&backgroundColor=dcfce7,b6e3f4,c0aede,d1d4f9,ffd5dc" class="w-9 h-9 rounded-lg bg-white" alt="">
                  <div>
                    <div class="font-semibold text-gray-900"><%= user.full_name %></div>
                    <div class="text-sm text-gray-500"><%= user.email %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= user.designation %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% user.roles.each do |role| %>
                  <span class="px-2 py-1 inline-flex text-xs font-bold rounded-full
                    <%= case role.name
                        when 'admin' then 'bg-purple-100 text-purple-700'
                        when 'moderator' then 'bg-blue-100 text-blue-700'
                        else 'bg-brand-100 text-brand-700'
                        end %>">
                    <%= role.name %>
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600 max-w-xs truncate"><%= user.topics.map(&:name).join(', ') %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full
                  <%= case user.status
                      when 'active' then 'bg-brand-100 text-brand-700'
                      when 'pending' then 'bg-amber-100 text-amber-700'
                      else 'bg-red-100 text-red-700'
                      end %>">
                  <%= user.status %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <% if user != current_user %>
                  <div class="flex items-center justify-end gap-3">
                    <% if user.status != 'active' %>
                      <%= link_to "Activate", update_status_admin_user_path(user, status: 'active'), data: { turbo_method: :patch }, class: "text-brand-600 hover:text-brand-700 font-semibold" %>
                    <% end %>
                    <% if user.status != 'suspended' %>
                      <%= link_to "Suspend", update_status_admin_user_path(user, status: 'suspended'), data: { turbo_method: :patch }, class: "text-amber-600 hover:text-amber-700 font-semibold" %>
                    <% end %>
                    <% if user.status != 'blocked' %>
                      <%= link_to "Block", update_status_admin_user_path(user, status: 'blocked'), data: { turbo_method: :patch }, class: "text-red-600 hover:text-red-700 font-semibold" %>
                    <% end %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-100">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Invite Modal -->
  <div x-show="showInviteModal" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-[60] flex items-center justify-center p-4" x-cloak>
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" @click="showInviteModal = false"></div>
    <div x-show="showInviteModal" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95 translate-y-4" x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 translate-y-4" class="bg-white rounded-3xl shadow-2xl w-full max-w-lg relative z-10 overflow-hidden">
      <div class="bg-gradient-to-br from-brand-600 to-brand-800 p-6 text-white text-center">
        <button @click="showInviteModal = false" class="absolute top-4 right-4 text-white/80 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <h3 class="text-2xl font-bold">Invite User</h3>
        <p class="text-brand-100 mt-1">Send a magic link invitation to a new user.</p>
      </div>
      <div class="p-8">
        <%= form_with url: invite_admin_users_path, method: :post, class: "space-y-5" do |f| %>
          <div>
            <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.email_field :email, required: true, placeholder: "user@example.com", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
          </div>
          <div>
            <%= f.label :full_name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.text_field :full_name, placeholder: "John Doe", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
          </div>
          <div>
            <%= f.label :designation, "Designation", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.text_field :designation, placeholder: "e.g. Software Engineer", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
          </div>
          <div>
            <%= f.label :role, "Role", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.select :role, options_for_select([["Subscriber", "subscriber"], ["Moderator", "moderator"], ["Admin", "admin"]]), {}, class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
          </div>
          <%= f.submit "Send Invitation", class: "w-full py-3 bg-brand-600 text-white rounded-xl font-bold hover:bg-brand-700 transition shadow-lg cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
