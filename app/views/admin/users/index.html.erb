<div class="min-h-screen bg-gray-50">
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-2">
          <div class="w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-700 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg">M</div>
          <span class="text-2xl font-bold text-gray-900">Mboka Admin</span>
        </div>
        <div class="flex items-center gap-6">
          <%= link_to "Dashboard", admin_dashboard_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Users", admin_users_path, class: "text-sm font-semibold text-brand-600 nav-link" %>
          <%= link_to "Digests", admin_digests_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Schedule", admin_digest_schedule_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Settings", admin_settings_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Payments", admin_payments_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Reports", admin_reports_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Sidekiq", "/admin/sidekiq", target: "_blank", class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
          <%= link_to "Profile", profile_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition nav-link" %>
        </div>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-black text-gray-900">User Management</h1>
      <div class="flex items-center gap-3">
        <%= link_to download_template_admin_users_path, class: "px-4 py-2 bg-white border border-gray-200 text-gray-700 text-sm font-bold rounded-xl hover:bg-gray-50 transition-all duration-200 shadow-sm flex items-center gap-2 btn-press" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Download Template
        <% end %>
        <div data-controller="csv-upload" class="flex items-center gap-3">
          <%= form_with url: import_admin_users_path, method: :post, multipart: true, class: "flex items-center gap-3", data: { csv_upload_target: "form" } do |f| %>
            <%= f.file_field :file, accept: '.csv', required: true, class: "text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 text-gray-500 cursor-pointer", data: { csv_upload_target: "input" } %>
            <button type="button" data-action="click->csv-upload#upload" class="px-4 py-2 bg-brand-600 text-white text-sm font-bold rounded-xl hover:bg-brand-700 cursor-pointer transition shadow-md">
              Bulk Import
            </button>
          <% end %>

          <!-- Progress Bar -->
          <div data-csv-upload-target="progress" class="hidden flex-1 max-w-xs">
            <div class="flex items-center gap-3">
              <div class="flex-1 bg-gray-200 rounded-full h-2.5 overflow-hidden">
                <div data-csv-upload-target="progressBar" class="bg-brand-600 h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
              </div>
              <span data-csv-upload-target="progressText" class="text-sm font-semibold text-gray-600">0%</span>
            </div>
          </div>

          <!-- Result Message -->
          <div data-csv-upload-target="result" class="hidden px-4 py-2 rounded-xl text-sm font-medium bg-green-50 border border-green-200 text-green-700">
            <span data-csv-upload-target="resultText"></span>
          </div>
        </div>
        <div x-data="{ showInviteModal: false }">
          <button type="button" @click="showInviteModal = true" class="px-4 py-2 bg-brand-600 text-white text-sm font-bold rounded-xl hover:bg-brand-700 cursor-pointer transition shadow-md flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            Invite User
          </button>

          <!-- Invite Modal -->
          <div x-show="showInviteModal" x-cloak class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
            <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
              <div x-show="showInviteModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 bg-black/40 transition-opacity backdrop-blur-sm" @click="showInviteModal = false"></div>
              <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
              <div x-show="showInviteModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative z-10 inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                  <h3 class="text-lg font-bold text-gray-900 mb-4">Invite New User</h3>
                  <%= form_with url: admin_invitations_path, method: :post, class: "space-y-4", data: { turbo: false } do |f| %>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                      <%= f.email_field :email, required: true, class: "w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                      <%= f.text_field :full_name, class: "w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">Designation</label>
                      <%= f.text_field :designation, class: "w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                      <%= f.select :role, options_for_select([["Subscriber", "subscriber"], ["Moderator", "moderator"], ["Admin", "admin"]]), {}, class: "w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm bg-white" %>
                    </div>
                    <div class="flex justify-end gap-3 pt-4">
                      <button type="button" @click="showInviteModal = false" class="px-4 py-2.5 border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition cursor-pointer">Cancel</button>
                      <%= f.submit "Send Invitation", class: "px-6 py-2.5 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition shadow-md cursor-pointer" %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div x-data="{ scrolled: false }" x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 120 })" class="sticky top-20 z-40 bg-white rounded-2xl shadow-lg border border-gray-100 mb-6 transition-all duration-500 ease-in-out" :class="scrolled ? 'p-3 ml-16' : 'p-6'">
      <%= form_with url: admin_users_path, method: :get, class: "space-y-3" do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 transition-all duration-500 ease-in-out" :class="scrolled ? 'gap-2' : 'gap-3'">
          <!-- Search -->
          <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Search</label>
            <%= f.text_field :search, value: params[:search], placeholder: "Search...", class: "w-full px-3 py-2 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
          </div>

          <!-- Role -->
          <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Role</label>
            <%= f.select :role, options_for_select(@roles.map { |r| [r.titleize, r] }, params[:role]), { include_blank: "All Roles" }, class: "w-full px-3 py-2 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm bg-white" %>
          </div>

          <!-- Topic -->
          <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Topic</label>
            <%= f.select :topic_id, options_from_collection_for_select(@topics, :id, :name, params[:topic_id]), { include_blank: "All Topics" }, class: "w-full px-3 py-2 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm bg-white" %>
          </div>

          <!-- Status -->
          <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Status</label>
            <%= f.select :status, options_for_select(["active", "pending", "suspended", "blocked"], params[:status]), { include_blank: "All Statuses" }, class: "w-full px-3 py-2 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm bg-white" %>
          </div>

          <!-- Per Page -->
          <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 transition-all duration-500 ease-in-out" :class="scrolled ? 'h-0 overflow-hidden opacity-0 mb-0' : 'opacity-100 mb-1'">Per Page</label>
            <%= f.select :per_page, options_for_select([10, 25, 50], @per_page), {}, class: "w-full px-3 py-2 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm bg-white" %>
          </div>
        </div>

        <div class="flex items-center gap-3 transition-all duration-500 ease-in-out overflow-hidden" :class="scrolled ? 'h-0 opacity-0' : 'opacity-100'">
          <%= f.submit "Apply Filters", class: "px-6 py-2.5 bg-brand-600 text-white text-sm font-bold rounded-xl hover:bg-brand-700 cursor-pointer transition shadow-md" %>
          <%= link_to "Clear Filters", admin_users_path, class: "px-4 py-2.5 text-sm font-medium text-gray-500 hover:text-gray-700 transition" %>
          <span class="text-sm text-gray-400 ml-auto"><%= @pagy.count %> users found</span>
        </div>
      <% end %>
    </div>

    <!-- Users Table with Endless Scroll -->
    <div class="flex items-start gap-6"
         data-controller="infinite-scroll"
         data-infinite-scroll-page-value="<%= @pagy.page %>"
         data-infinite-scroll-total-pages-value="<%= @pagy.pages %>"
         data-infinite-scroll-base-url-value="<%= admin_users_path(request.query_parameters.except(:page)) %>">
      <!-- Animated Page Numbers -->
      <%= render "shared/page_indicator", pagy: @pagy, current_page: @pagy.page %>

      <div class="flex-1 bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
          <table class="min-w-full divide-y divide-gray-100">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">User</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Designation</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Role</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Topics</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-gray-500">Status</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-gray-500">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50" data-infinite-scroll-target="container">
              <% @users.each do |user| %>
                <tr class="table-row-hover" data-digest-card>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center gap-3">
                      <img src="https://api.dicebear.com/9.x/adventurer-neutral/svg?seed=<%= user.id %>&backgroundColor=fef3c7,fde68a,dcfce7,b6e3f4,c0aede,d1d4f9,ffd5dc,fed7aa,fecdd3" class="w-9 h-9 rounded-lg bg-white" alt="">
                      <div>
                        <%= link_to admin_user_path(user), class: "font-semibold text-gray-900 hover:text-brand-600 transition" do %>
                          <%= user.full_name %>
                        <% end %>
                        <div class="text-sm text-gray-500"><%= user.email %></div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= user.designation %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if user != current_user %>
                      <% role_color = case user.roles.first&.name
                         when 'admin' then 'bg-purple-100 text-purple-700'
                         when 'moderator' then 'bg-blue-100 text-blue-700'
                         else 'bg-brand-100 text-brand-700'
                         end %>
                      <%= form_with url: update_role_admin_user_path(user), method: :patch, class: "inline-flex" do |f| %>
                        <%= f.select :role, options_for_select([["Admin", "admin"], ["Moderator", "moderator"], ["Subscriber", "subscriber"]], user.roles.first&.name), {}, onchange: "this.form.submit()", class: "text-xs font-bold rounded-full px-3 py-1 border-0 cursor-pointer focus:ring-2 focus:ring-brand-200 #{role_color}" %>
                      <% end %>
                    <% else %>
                      <% user.roles.each do |role| %>
                        <% badge_color = case role.name
                           when 'admin' then 'bg-purple-100 text-purple-700'
                           when 'moderator' then 'bg-blue-100 text-blue-700'
                           else 'bg-brand-100 text-brand-700'
                           end %>
                        <span class="px-2 py-1 inline-flex text-xs font-bold rounded-full <%= badge_color %>">
                          <%= role.name %>
                        </span>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex flex-wrap gap-1 max-w-xs">
                      <% user.topics.limit(3).each do |topic| %>
                        <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full"><%= topic.name %></span>
                      <% end %>
                      <% if user.topics.count > 3 %>
                        <span class="px-2 py-0.5 bg-gray-100 text-gray-500 text-xs rounded-full">+<%= user.topics.count - 3 %></span>
                      <% end %>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 inline-flex text-xs font-bold rounded-full badge-pulse
                      <%= case user.status
                          when 'active' then 'bg-brand-100 text-brand-700'
                          when 'pending' then 'bg-amber-100 text-amber-700'
                          else 'bg-red-100 text-red-700'
                          end %>">
                      <%= user.status %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <% if user != current_user %>
                      <div class="flex items-center justify-end gap-3">
                        <% if user.status != 'active' %>
                          <%= link_to "Activate", update_status_admin_user_path(user, status: 'active'), data: { turbo_method: :patch }, class: "text-brand-600 hover:text-brand-700 font-semibold transition-all duration-200" %>
                        <% end %>
                        <% if user.status != 'suspended' %>
                          <%= link_to "Suspend", update_status_admin_user_path(user, status: 'suspended'), data: { turbo_method: :patch }, class: "text-amber-600 hover:text-amber-700 font-semibold transition-all duration-200" %>
                        <% end %>
                        <% if user.status != 'blocked' %>
                          <%= link_to "Block", update_status_admin_user_path(user, status: 'blocked'), data: { turbo_method: :patch }, class: "text-red-600 hover:text-red-700 font-semibold transition-all duration-200" %>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>

          <% if @pagy.page < @pagy.pages %>
            <div data-infinite-scroll-trigger class="py-4 text-center">
              <div class="inline-flex items-center gap-2 text-sm text-gray-400">
                <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                Loading more users...
              </div>
            </div>
          <% end %>

        <!-- Footer -->
        <div class="bg-gray-50 px-6 py-4 border-t border-gray-100">
          <span class="text-sm text-gray-500">
            Showing page <span class="font-semibold text-gray-700" data-current-page><% @pagy.page.to_s.chars.each do |c| %><span class="digit inline-block"><%= c %></span><% end %></span> of <%= @pagy.pages %> (<%= @pagy.count %> users)
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
