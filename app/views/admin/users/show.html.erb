<div class="min-h-screen bg-gray-50">
  <%= render "shared/admin_nav" %>

  <div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <!-- Back Link -->
    <div class="mb-6">
      <%= link_to admin_users_path, class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-700 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Users
      <% end %>
    </div>

    <!-- Profile Header Card -->
    <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden mb-6 relative">
      <%= topographic_pattern_svg(@profile_user, pattern_id: "admin-topo") %>

      <!-- Profile Info -->
      <div class="px-8 pb-8 -mt-12 relative z-10">
        <div class="flex items-end gap-5">
          <img src="https://api.dicebear.com/9.x/adventurer-neutral/svg?seed=<%= @profile_user.id %>&backgroundColor=fef3c7,fde68a,dcfce7,b6e3f4,c0aede,d1d4f9,ffd5dc,fed7aa,fecdd3" alt="<%= @profile_user.full_name %>" class="w-24 h-24 rounded-2xl shadow-lg border-4 border-white bg-white" />
          <div class="flex-1 pb-1">
            <div class="flex items-center gap-3 mb-1">
              <h1 class="text-2xl font-black text-gray-900"><%= @profile_user.full_name %></h1>
              <% @profile_user.roles.each do |role| %>
                <% badge_color = case role.name
                   when 'admin' then 'bg-purple-100 text-purple-700'
                   when 'moderator' then 'bg-blue-100 text-blue-700'
                   else 'bg-brand-100 text-brand-700'
                   end %>
                <span class="px-2.5 py-0.5 text-xs font-bold rounded-full <%= badge_color %>"><%= role.name %></span>
              <% end %>
            </div>
            <p class="text-gray-600 font-medium"><%= @profile_user.designation %></p>
            <p class="text-sm text-gray-400 mt-0.5"><%= @profile_user.email %></p>
            <div class="flex items-center gap-4 mt-3">
              <span class="px-3 py-1 inline-flex text-xs font-bold rounded-full
                <%= case @profile_user.status
                    when 'active' then 'bg-brand-100 text-brand-700'
                    when 'pending' then 'bg-amber-100 text-amber-700'
                    else 'bg-red-100 text-red-700'
                    end %>">
                <%= @profile_user.status %>
              </span>
              <span class="text-sm text-gray-500">Joined <%= @profile_user.created_at.strftime("%b %d, %Y") %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Topics -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-6">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-bold text-gray-900">Subscribed Topics</h3>
        <span class="text-sm font-bold text-brand-600"><%= @profile_user.topics.count %> topics</span>
      </div>
      <% if @profile_user.topics.any? %>
        <div class="flex flex-wrap gap-2">
          <% @profile_user.topics.each do |topic| %>
            <span class="px-4 py-2 bg-brand-50 text-brand-700 text-sm font-semibold rounded-xl border border-brand-100"><%= topic.name %></span>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-400 text-sm">No topics selected yet.</p>
      <% end %>
    </div>

    <!-- Favorited Digests -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Favorited Digests
        </h3>
        <span class="text-sm font-bold text-brand-600"><%= @pagy_favorites.count %> favorites</span>
      </div>

      <% if @favorited_digests.any? %>
        <div class="flex items-start gap-6"
             data-controller="infinite-scroll"
             data-infinite-scroll-page-value="<%= @pagy_favorites.page %>"
             data-infinite-scroll-total-pages-value="<%= @pagy_favorites.pages %>"
             data-infinite-scroll-base-url-value="<%= admin_user_path(@profile_user) %>">
          <!-- Animated Page Numbers -->
          <%= render "shared/page_indicator", pagy: @pagy_favorites, current_page: @pagy_favorites.page %>

          <div class="flex-1 space-y-4">
            <div data-infinite-scroll-target="container" class="space-y-4">
              <% @favorited_digests.each do |digest| %>
                <div data-digest-card>
                  <%= link_to topic_digest_path(digest), data: { turbo: false }, class: "block p-5 bg-gray-50 rounded-xl border border-gray-100 hover:border-brand-200 hover:shadow-md transition group" do %>
                    <div class="flex items-center justify-between mb-3">
                      <div class="flex items-center gap-2">
                        <span class="px-3 py-1 bg-brand-100 text-brand-700 text-xs font-bold rounded-full"><%= digest.topic.name %></span>
                        <span class="text-xs text-gray-400">Week of <%= digest.week_of.strftime("%b %d, %Y") %></span>
                      </div>
                      <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    </div>
                    <div class="text-sm text-gray-600 line-clamp-2 group-hover:text-gray-800 transition">
                      <%= strip_tags(digest.content).truncate(150) %>
                    </div>
                    <div class="mt-3 flex items-center gap-1 text-xs font-semibold text-brand-600 opacity-0 group-hover:opacity-100 transition">
                      View full digest
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <% if @pagy_favorites.page < @pagy_favorites.pages %>
              <div data-infinite-scroll-trigger class="py-4 text-center">
                <div class="inline-flex items-center gap-2 text-sm text-gray-400">
                  <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                  Loading more...
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          <p class="text-gray-400 text-sm">No favorited digests yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
