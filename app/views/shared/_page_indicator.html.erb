<%# Usage: render "shared/page_indicator", pagy: @pagy, current_page: @pagy.page %>
<% if pagy.pages > 1 %>
  <div class="hidden lg:flex flex-col items-center gap-3 sticky top-24 z-40 pt-4 transition-all duration-500" data-page-numbers>
    <% (1..[pagy.pages, 10].min).each do |page_num| %>
      <button type="button"
              data-page-num="<%= page_num %>"
              data-action="click->infinite-scroll#goToPage"
              class="w-10 h-10 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 ease-out cursor-pointer
                     <%= page_num == current_page ? 'bg-brand-500 text-white scale-110 shadow-lg ring-2 ring-brand-300 ring-offset-2' : 'bg-gray-100 text-gray-400 hover:bg-gray-200 hover:text-gray-600 hover:scale-110 hover:shadow-md' %>">
        <span class="flex items-center justify-center">
          <% page_num.to_s.chars.each do |digit| %>
            <span class="digit inline-block transition-all duration-150"><%= digit %></span>
          <% end %>
        </span>
      </button>
    <% end %>

    <% if pagy.pages > 10 %>
      <div class="w-10 h-10 rounded-full flex items-center justify-center text-xs text-gray-400">
        <span class="text-[10px]">...</span>
      </div>
    <% end %>
  </div>
<% end %>
