<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="max-w-lg w-full">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-br from-amber-500 to-amber-700 p-8 text-white text-center">
        <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h1 class="text-2xl font-bold mb-2">Free Trial Expired</h1>
        <p class="text-amber-100">Your 30-day trial has ended.</p>
      </div>

      <!-- Content -->
      <div class="p-8">
        <div class="text-center mb-6">
          <p class="text-gray-600 mb-4">
            To continue using Mboka and receiving intelligence digests, please make your first payment installment.
          </p>
          <div class="bg-brand-50 border border-brand-200 rounded-xl p-4">
            <p class="text-sm text-brand-800">
              <strong>$500</strong> per installment &bull; 4 installments &bull; 30 days access each
            </p>
          </div>
        </div>

        <% if defined?(current_user) && current_user&.has_role?(:admin) %>
          <div class="mt-6">
            <%= link_to admin_payments_path, class: "w-full inline-flex items-center justify-center gap-2 px-6 py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition shadow-lg" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              Go to Payments
            <% end %>
          </div>
        <% else %>
          <div class="mt-6 text-center">
            <p class="text-sm text-gray-500 mb-3">Are you the administrator?</p>
            <%= link_to "Admin Login", new_user_session_path, class: "text-brand-600 font-semibold hover:text-brand-700 transition" %>
          </div>
        <% end %>
      </div>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      Mboka &mdash; East Africa Intelligence Digest
    </p>
  </div>
</div>
