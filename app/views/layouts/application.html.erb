<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Mboka" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="turbo-cache-control" content="no-cache">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <% if AdminSetting.instance.google_analytics_id.present? %>
      <!-- Google tag (gtag.js) -->
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= AdminSetting.instance.google_analytics_id %>"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', '<%= AdminSetting.instance.google_analytics_id %>');
      </script>
    <% end %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <style>
      [x-cloak] { display: none !important; }
      .gradient-text {
        background: linear-gradient(135deg, #16a34a 0%, #f59e0b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .topic-checkbox:checked + div {
        background-color: #dcfce7;
        border-color: #16a34a;
        color: #15803d;
      }
      .topic-checkbox:checked + div .check-icon {
        opacity: 1;
        transform: scale(1);
      }
      .swiper-pagination-bullet-active {
        background-color: #16a34a !important;
        width: 24px !important;
        border-radius: 4px !important;
      }
    </style>
  </head>

  <body class="h-full font-sans antialiased bg-gray-50 text-gray-800" style="font-family: 'Inter', sans-serif;">
    <script>
      function playToastSound(type) {
        try {
          const ctx = new (window.AudioContext || window.webkitAudioContext)();
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.connect(gain);
          gain.connect(ctx.destination);
          gain.gain.setValueAtTime(0.15, ctx.currentTime);
          if (type === 'success') {
            osc.frequency.setValueAtTime(587, ctx.currentTime);
            osc.frequency.setValueAtTime(784, ctx.currentTime + 0.08);
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.25);
            osc.start(ctx.currentTime);
            osc.stop(ctx.currentTime + 0.25);
          } else {
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(220, ctx.currentTime);
            osc.frequency.setValueAtTime(165, ctx.currentTime + 0.1);
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
            osc.start(ctx.currentTime);
            osc.stop(ctx.currentTime + 0.3);
          }
        } catch(e) {}
      }
    </script>
    <div id="flash-messages">
      <% flash.each do |type, message| %>
        <div data-controller="flash" data-flash-type-value="<%= type %>" data-flash-message-value="<%= j message %>"></div>
      <% end %>
    </div>

    <div x-data="{ showSubscribeModal: false }" @open-subscribe.window="showSubscribeModal = true">
      <%= yield %>

      <!-- Subscription Modal -->
    <div x-show="showSubscribeModal" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-[60] flex items-center justify-center p-4" x-cloak>
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" @click="showSubscribeModal = false"></div>
      <div x-show="showSubscribeModal" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95 translate-y-4" x-transition:enter-end="opacity-100 scale-100 translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 scale-100 translate-y-0" x-transition:leave-end="opacity-0 scale-95 translate-y-4" class="bg-white rounded-3xl shadow-2xl w-full max-w-2xl relative z-10 overflow-hidden max-h-[90vh] overflow-y-auto">
        <div class="bg-gradient-to-br from-brand-600 to-brand-800 p-8 text-white text-center sticky top-0 z-20">
          <button @click="showSubscribeModal = false" class="absolute top-4 right-4 text-white/80 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
          <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-2xl font-bold mb-2">Subscribe to Mboka Weekly</h3>
          <p class="text-brand-100">Get tailored opportunities delivered to your inbox every Monday.</p>
        </div>
        <div class="p-8">
          <%= form_with scope: :subscriber, url: subscribers_path, class: "space-y-6" do |f| %>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <%= f.label :full_name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :full_name, required: true, placeholder: "John Doe", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
              </div>
              <div>
                <%= f.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.email_field :email, required: true, placeholder: "john@example.com", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
              </div>
            </div>

            <div>
              <%= f.label :designation, "What best describes you?", class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.text_field :designation, required: true, placeholder: "e.g. Senior Software Engineer", class: "w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition text-sm" %>
            </div>

            <% if @topics.present? %>
              <div>
                <div class="flex justify-between items-center mb-3">
                  <label class="block text-sm font-medium text-gray-700">Select Your Topics</label>
                  <span class="text-sm font-bold text-brand-600">Choose at least one</span>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                  <% @topics.each do |topic| %>
                    <label class="cursor-pointer relative">
                      <input type="checkbox" name="subscriber[topic_ids][]" value="<%= topic.id %>" class="sr-only topic-checkbox">
                      <div class="p-3 rounded-xl border-2 border-gray-200 hover:border-brand-300 transition flex items-center justify-between group">
                        <span class="text-sm font-medium text-gray-700"><%= topic.name %></span>
                        <svg class="w-5 h-5 text-brand-600 opacity-0 transform scale-50 transition-all duration-200 check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      </div>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%= f.submit "Start My Free Subscription", class: "w-full py-4 bg-brand-600 text-white rounded-xl font-bold text-lg hover:bg-brand-700 transition shadow-lg flex items-center justify-center gap-2 cursor-pointer transform hover:-translate-y-0.5" %>
          <% end %>
          <p class="text-xs text-gray-500 text-center mt-4">No spam, unsubscribe anytime. Read our <%= link_to "Privacy Policy", privacy_path, class: "text-brand-600 underline" %>.</p>
        </div>
      </div>
    </div>
    </div>
  </body>
</html>
