<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Mboka" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full font-sans antialiased selection:bg-emerald-500/30 selection:text-emerald-200">
    <!-- Clean, globally accessible system notification alerts -->
    <% if flash.any? %>
      <div class="fixed top-4 right-4 z-50 space-y-2 max-w-sm">
        <% flash.each do |type, message| %>
          <div class="p-4 rounded-lg border shadow-xl backdrop-blur-md <%= type == 'notice' ? 'bg-emerald-950/80 border-emerald-800 text-emerald-200' : 'bg-rose-950/80 border-rose-800 text-rose-200' %>">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
