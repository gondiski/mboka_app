<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #1e293b; margin: 0; padding: 0; background-color: #f1f5f9; -webkit-font-smoothing: antialiased; }
      .wrapper { background-color: #f1f5f9; padding: 32px 16px; }
      .container { max-width: 560px; margin: 0 auto; }
      .card { background: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 10px 15px -3px rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.04); }
      .header { background: linear-gradient(135deg, #16a34a 0%, #15803d 50%, #166534 100%); padding: 48px 40px 40px; text-align: center; position: relative; overflow: hidden; }
      .header::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle at 30% 40%, rgba(255,255,255,0.12) 0%, transparent 50%); }
      .header::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 24px; background: #ffffff; border-radius: 24px 24px 0 0; }
      .logo { width: 52px; height: 52px; background: rgba(255,255,255,0.2); border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 20px; position: relative; backdrop-filter: blur(8px); }
      .logo-text { color: white; font-size: 26px; font-weight: 800; }
      .header h1 { color: white; margin: 0; font-size: 24px; font-weight: 800; position: relative; letter-spacing: -0.02em; }
      .content { padding: 8px 40px 40px; }
      .greeting { font-size: 22px; font-weight: 700; color: #0f172a; margin: 0 0 6px; letter-spacing: -0.01em; }
      .subtitle { font-size: 15px; color: #64748b; margin: 0 0 24px; }
      .body-text { font-size: 15px; color: #475569; line-height: 1.75; margin-bottom: 24px; }
      .highlight-box { background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); border: 1px solid #bbf7d0; border-radius: 12px; padding: 20px 24px; margin: 24px 0; }
      .highlight-box h3 { font-size: 14px; font-weight: 700; color: #15803d; margin: 0 0 8px; }
      .highlight-box ul { margin: 0; padding-left: 18px; }
      .highlight-box li { font-size: 14px; color: #166534; margin-bottom: 4px; }
      .cta-btn { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); color: white; font-size: 16px; font-weight: 700; text-decoration: none; border-radius: 12px; transition: all 0.2s; margin: 8px 0 24px; }
      .cta-btn:hover { background: linear-gradient(135deg, #15803d 0%, #166534 100%); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(22,163,74,0.3); }
      .divider { height: 1px; background: linear-gradient(to right, transparent, #e2e8f0, transparent); margin: 24px 0; }
      .footer { padding: 28px 40px; background: #f8fafc; border-top: 1px solid #f1f5f9; text-align: center; border-radius: 0 0 20px 20px; }
      .footer-brand { font-size: 16px; font-weight: 800; color: #16a34a; margin-bottom: 12px; letter-spacing: -0.02em; }
      .footer-note { font-size: 12px; color: #94a3b8; line-height: 1.6; }
      .fallback-link { font-size: 13px; color: #64748b; margin-top: 16px; word-break: break-all; }
      .fallback-link a { color: #16a34a; text-decoration: underline; }
      @media only screen and (max-width: 600px) {
        .wrapper { padding: 16px 8px; }
        .header { padding: 36px 24px 32px; }
        .content { padding: 8px 24px 32px; }
        .footer { padding: 24px; }
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <div class="card">
          <div class="header">
            <div class="logo">
              <span class="logo-text">M</span>
            </div>
            <h1>You've Been Invited</h1>
          </div>
          <div class="content">
            <h2 class="greeting">Hi <%= @user.email_display_name %>,</h2>
            <p class="subtitle">You've been invited to join Mboka, an intelligence digest platform.</p>

            <p class="body-text">
              Mboka delivers weekly intelligence digests on the topics you care about — curated by AI and delivered to your inbox.
            </p>

            <div class="highlight-box">
              <h3>What you'll get:</h3>
              <ul>
                <li>Weekly curated intelligence digests</li>
                <li>Choose from 30+ topics across industries</li>
                <li>Personalized to your interests</li>
                <li>Manage your preferences anytime</li>
              </ul>
            </div>

            <p class="body-text">
              Click the button below to accept your invitation and get started:
            </p>

            <a href="<%= @login_url %>" class="cta-btn">
              Accept Invitation
            </a>

            <p class="fallback-link">
              If the button doesn't work, copy and paste this link into your browser:<br>
              <a href="<%= @login_url %>"><%= @login_url %></a>
            </p>
          </div>
          <div class="footer">
            <p class="footer-brand">Mboka</p>
            <p class="footer-note">This invitation was sent by an administrator. If you didn't expect this, you can safely ignore this email.</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
