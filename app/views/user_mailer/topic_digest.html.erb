<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #334155; margin: 0; padding: 0; background-color: #f8fafc; -webkit-font-smoothing: antialiased; }
      h1, h2, h3, h4 { font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
      .wrapper { background-color: #f8fafc; padding: 40px 16px; }
      .container { max-width: 600px; margin: 0 auto; }
      .header { background-color: #020617; padding: 48px 40px; position: relative; border-bottom: 4px solid #059669; }
      .header-bg { position: absolute; top: 0; right: 0; bottom: 0; left: 0; background: radial-gradient(circle at top right, #064e3b 0%, transparent 60%); opacity: 0.8; z-index: 1; }
      .header-content { position: relative; z-index: 2; }
      .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; }
      .logo { display: inline-block; }
      .logo-text { color: #ffffff; font-size: 24px; font-weight: 800; font-family: 'Outfit', sans-serif; letter-spacing: -0.04em; margin: 0; }
      .logo-dot { color: #34d399; }
      .date-pill { display: inline-block; background-color: rgba(255,255,255,0.08); color: #e2e8f0; font-size: 13px; font-weight: 600; padding: 6px 16px; border-radius: 20px; font-family: 'Inter', sans-serif; border: 1px solid rgba(255,255,255,0.1); }
      .header h1 { color: #ffffff; margin: 0 0 16px; font-size: 38px; font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; text-align: left; }
      .header-highlight { color: #34d399; }
      .header p { color: #94a3b8; margin: 0; font-size: 16px; font-weight: 400; text-align: left; max-width: 85%; line-height: 1.5; }
      .content { padding: 40px 40px 48px; }
      .greeting { font-size: 24px; font-weight: 800; color: #0f172a; margin: 0 0 8px; letter-spacing: -0.02em; }
      .subtitle { font-size: 16px; color: #64748b; margin: 0 0 32px; font-weight: 400; }
      .topic-section { padding: 32px 0; border-top: 1px solid #f1f5f9; }
      .topic-section:first-of-type { padding-top: 0; border-top: none; }
      .topic-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
      .topic-name { font-size: 20px; font-weight: 800; color: #059669; margin: 0; letter-spacing: -0.01em; }
      .topic-badge { font-size: 12px; background: #ecfdf5; color: #059669; padding: 6px 14px; border-radius: 20px; font-weight: 600; font-family: 'Outfit', sans-serif; letter-spacing: 0.02em; }
      .topic-content { font-size: 15px; color: #475569; line-height: 1.8; }
      .topic-content h2, .topic-content h3 { font-size: 18px; color: #0f172a; margin: 24px 0 12px; font-weight: 700; letter-spacing: -0.01em; }
      .topic-content p { margin: 0 0 16px; }
      .topic-content a { color: #059669; text-decoration: none; font-weight: 600; }
      .topic-content a:hover { text-decoration: underline; }
      .btn-container { margin-top: 24px; }
      .view-more-btn { display: inline-block; background-color: #059669; color: #ffffff !important; font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 600; text-decoration: none; padding: 12px 24px; border-radius: 12px; transition: background-color 0.2s; }
      .view-more-btn:hover { background-color: #047857; text-decoration: none !important; }
      .footer { padding: 32px 40px; background: #f8fafc; border-top: 1px solid #f1f5f9; text-align: center; border-radius: 0 0 24px 24px; }
      .footer-brand { font-size: 18px; font-weight: 800; color: #059669; font-family: 'Outfit', sans-serif; margin-bottom: 16px; letter-spacing: -0.02em; }
      .footer-links { margin-bottom: 16px; }
      .footer-links a { font-size: 14px; color: #64748b; text-decoration: none; margin: 0 12px; font-weight: 500; transition: color 0.2s; }
      .footer-links a:hover { color: #059669; }
      .footer-note { font-size: 13px; color: #94a3b8; line-height: 1.6; margin: 0; }
      @media only screen and (max-width: 600px) {
        .wrapper { padding: 16px 8px; }
        .header { padding: 40px 24px; }
        .header h1 { font-size: 32px; }
        .content { padding: 32px 24px 40px; }
        .footer { padding: 24px; }
        .topic-header { flex-direction: column; align-items: flex-start; gap: 8px; }
        .header-top { margin-bottom: 32px; }
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <div class="card">
          <div class="header">
            <div class="header-bg"></div>
            <div class="header-content">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="header-top">
                <tr>
                  <td align="left">
                    <div class="logo">
                      <span class="logo-text">mboka<span class="logo-dot">.</span></span>
                    </div>
                  </td>
                  <td align="right">
                    <div class="date-pill">
                      <%= Date.current.strftime('%b %d, %Y') %>
                    </div>
                  </td>
                </tr>
              </table>
              <h1>
                Your Intelligence<br>
                <span class="header-highlight">Briefing</span>
              </h1>
              <p>The most critical updates and top jobs across your subscribed topics, delivered straight to you.</p>
            </div>
          </div>
          <div class="content">
            <h2 class="greeting">Hi <%= @greeting %>,</h2>
            <p class="subtitle">Here are the most critical updates across your topics.</p>

            <% @topic_digests.each do |digest| %>
              <div class="topic-section">
                <div class="topic-header">
                  <h3 class="topic-name"><%= digest.topic.name %></h3>
                  <span class="topic-badge">Week of <%= digest.week_of.strftime("%b %d") %></span>
                </div>
                <div class="topic-content">
                  <% insights_content = digest.content.split('<!-- JOBS_SECTION -->').first %>
                  <%= raw inject_utm_links(insights_content, source: "digest_email", medium: "email", campaign: digest.topic.name.parameterize, content: digest.id) %>
                </div>
                <div class="btn-container">
                  <a href="<%= topic_digest_url(digest, utm_source: 'digest_email', utm_medium: 'email', utm_campaign: digest.topic.name.parameterize, utm_content: digest.id) %>" style="color: #059669; font-weight: 600; font-size: 15px; text-decoration: none; font-family: 'Inter', sans-serif;">
                    See More Jobs &rarr;
                  </a>
                </div>
              </div>
            <% end %>

          </div>
          <div class="footer">
            <p class="footer-brand">Mboka</p>
            <div class="footer-links">
              <a href="<%= @preferences_url %>">Manage Preferences</a>
              <a href="<%= @unsubscribe_url %>">Unsubscribe</a>
            </div>
            <p class="footer-note">You received this digest because you're subscribed to these topics on Mboka.</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
